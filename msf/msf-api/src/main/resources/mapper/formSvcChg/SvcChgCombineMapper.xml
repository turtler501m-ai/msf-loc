<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktmmobile.msf.formSvcChg.mapper.SvcChgCombineMapper">

    <!--
        마스터 결합 회선 정보 목록.
        공통코드 MSF_CD_DTL의 GROUP_CD='MasterCombineLineInfo' 항목.
        DTL_CD=mstSvcContId, DTL_CD_NM=표시명.
    -->
    <select id="selectMasterCombineLine" resultType="map">
        SELECT
            DTL_CD     AS "dtlCd",
            DTL_CD_NM  AS "dtlCdNm",
            SORT_SEQ   AS "sortSeq"
        FROM MSF_CD_DTL
        WHERE GROUP_CD = 'MasterCombineLineInfo'
          AND USE_YN   = 'Y'
        ORDER BY SORT_SEQ
    </select>

    <!--
        요금제-아무나SOLO 할인부가 매핑 조회.
        ASIS: MypageMapper.selectMspCombRateMapp (MSP_MSC_COMB_RATE_MAPP@DL_MSP).
        rateCd로 해당 요금제에 적용 가능한 아무나SOLO 할인 SOC 조회.
    -->
    <select id="selectCombRateMapp" parameterType="map" resultType="map">
        SELECT
            RATE_CD    AS "rateCd",
            COMB_SOC   AS "combSoc",
            COMB_SOC_NM AS "combSocNm"
        FROM MSP_MSC_COMB_RATE_MAPP@DL_MSP
        WHERE RATE_CD = #{rateCd}
    </select>

</mapper>
