<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktmmobile.msf.formSvcChg.mapper.SvcChgBaseMapper">

    <!--
        서비스변경 업무 카테고리 목록 조회.
        공통코드 MSF_CD_GROUP_BAS 에서 SVC_TGT_CD 그룹 1건 조회.
    -->
    <select id="selectSvcChgCategories"
            resultType="com.ktmmobile.msf.formSvcChg.dto.SvcChgBaseCategoryDto">
        SELECT
            CD_GROUP_ID AS groupCd,
            CD_GROUP_NM AS groupNm,
            CD_GROUP_CD AS svcTgtCd,
            0           AS sortSeq
        FROM MSF_CD_GROUP_BAS
        WHERE CD_GROUP_ID = 'SVC_TGT_CD'
          AND USE_YN = 'Y'
    </select>

    <!--
        카테고리별 상세 옵션 목록 조회.
        공통코드 MSF_CD_DTL 에서 CD_GROUP_ID 기준 상세코드 조회.
        EXPNSN_STR_VAL1 = 동시처리차단여부, EXPNSN_STR_VAL2 = 이미징여부
    -->
    <select id="selectSvcChgOptions"
            parameterType="string"
            resultType="com.ktmmobile.msf.formSvcChg.dto.SvcChgBaseOptionDto">
        SELECT
            DTL_CD          AS dtlCd,
            DTL_CD_NM       AS dtlCdNm,
            EXPNSN_STR_VAL1 AS concurrentAvailYn,
            EXPNSN_STR_VAL2 AS imagingYn,
            SORT_ODRG       AS sortSeq
        FROM MSF_CD_DTL
        WHERE CD_GROUP_ID = #{groupCd}
          AND USE_YN = 'Y'
        ORDER BY SORT_ODRG
    </select>

</mapper>
