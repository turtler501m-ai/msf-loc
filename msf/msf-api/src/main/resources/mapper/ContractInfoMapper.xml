<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktmmobile.msf.formComm.mapper.ContractInfoMapper">

    <!--
        고객명 + 전화번호로 계약번호(ncn), 고객ID(custId) 조회.
        ASIS: MypageMapper.xml selectContractNum 과 동일 구조.
        로컬: PostgreSQL → LIMIT 1 / 운영 M전산(Oracle): LIMIT 1 → AND ROWNUM = 1 교체 필요.
    -->
    <select id="selectContractInfo"
            parameterType="map"
            resultType="com.ktmmobile.msf.formComm.dto.ContractInfoDto">
        SELECT
            CONTRACT_NUM AS ncn,
            CUSTOMER_ID  AS custId
        FROM MSP_JUO_SUB_INFO
        WHERE SUBSCRIBER_NO  = #{ctn}
          AND SUB_LINK_NAME  = #{name}
        LIMIT 1
    </select>


    <!--
        계약번호(ncn)로 청구계정ID(BAN) 조회.
        ASIS: MypageMapper.xml selectBanSel 동일 구조.
        운영 M전산(Oracle): LIMIT 1 → AND ROWNUM = 1 교체 필요.
    -->
    <select id="selectBanByContractNum"
            parameterType="string"
            resultType="string">
        SELECT CUSTOMER_ID
        FROM MSP_JUO_SUB_INFO
        WHERE CONTRACT_NUM = #{contractNum}
        LIMIT 1
    </select>

</mapper>
