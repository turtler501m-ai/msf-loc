    <!--<update id="updatePageViewCount" parameterType="com.ktmmobile.mcp.common.dto.McpIpStatisticDto">
        MERGE INTO MCP_PAGE_VIEWS a
        USING (SELECT #{url} AS URL, #{platformCd} AS PLATFORM_CD FROM DUAL) b
        ON (a.URL = b.URL AND a.PLATFORM_CD = b.PLATFORM_CD)
        WHEN MATCHED THEN
            UPDATE SET a.VIEW_COUNT = a.VIEW_COUNT + 1
        WHEN NOT MATCHED THEN
            INSERT (URL, VIEW_COUNT, PLATFORM_CD)
            VALUES (#{url}, 1, #{platformCd})
    </update>-->

    <!--<select id="selectPageViewsCount" resultType="java.lang.Integer">
      SELECT
        SUM(VIEW_COUNT) AS TOTAL_VIEW_COUNT
      FROM MCP_PAGE_VIEWS
      WHERE url IN (
          #{url},
          CASE
            WHEN #{url} LIKE '/m/%' THEN SUBSTR(#{url}, 3)
            ELSE CONCAT('/m', #{url})
          END
       )
    </select>-->

