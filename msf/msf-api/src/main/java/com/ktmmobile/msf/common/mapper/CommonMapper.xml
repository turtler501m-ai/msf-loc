    <!--<select id="getPopupAllList"  resultType="com.ktmmobile.mcp.common.dto.PopupDto">
    <![CDATA[
        SELECT /* CommonMapper.getPopupAllList */
            A.POPUP_SEQ
             , A.POPUP_SUBJECT
             , A.WIDTH_SIZE
             , A.HEIGHT_SIZE
             , A.XCRD
             , A.YCRD
             , A.POPUP_OPEN_STAT
             , TO_CHAR(A.PSTNG_START_DATE, 'YYYYMMDDHH24MISS') AS PSTNG_START_DATE
             , TO_CHAR(A.PSTNG_END_DATE, 'YYYYMMDDHH24MISS') AS PSTNG_END_DATE
             , A.PLATFORM_CD
             , A.OUTPUT_MENU
             , A.POPUP_OUTPUT_CD
             , A.INDC_ODRG
             , B.POPUP_SHOW_URL AS POPUP_SHOW_URL
             , A.POPUP_URL
             , A.CONTENT_TYPE
             , A.USAGE_TYPE
             , A.ONE_TIME_POPUP_GRP
             , C.DEVICE
             , C.POPUP_SBST
             , C.FILE_PATH_NM
        FROM
            NMCP_POPUP_BAS A
           , NMCP_POPUP_URL B
           , ( SELECT COALESCE(PE.POPUP_SEQ, PI.POPUP_SEQ) AS POPUP_SEQ
                      , COALESCE(PE.DEVICE, PI.DEVICE) AS DEVICE
                      , PE.POPUP_SBST
                      , PI.FILE_PATH_NM
                 FROM NMCP_POPUP_EDITOR PE
                 FULL OUTER JOIN NMCP_POPUP_IMAGE PI
                   ON PE.POPUP_SEQ = PI.POPUP_SEQ AND PE.DEVICE = PI.DEVICE ) C
        WHERE 1 = 1
          AND A.POPUP_SEQ = B.POPUP_SEQ(+)
          AND A.POPUP_SEQ = C.POPUP_SEQ(+)
          AND A.STAT_VAL = 'Y'
        ORDER BY A.OUTPUT_MENU, A.INDC_ODRG
        ]]>
    </select>-->

    <!--<select id="getPopupList"  parameterType="com.ktmmobile.mcp.common.dto.PopupDto"  resultType="com.ktmmobile.mcp.common.dto.PopupDto">
        SELECT /* CommonMapper.getPopupList */
            A.POPUP_SEQ, A.POPUP_SUBJECT, A.WIDTH_SIZE, A.HEIGHT_SIZE, XCRD, YCRD, POPUP_URL, POPUP_OPEN_STAT
        FROM
            NMCP_POPUP_BAS A
           , (SELECT MENU_CODE, URL_ADR, GROUP_KEY FROM NMCP_USER_MENU_BAS WHERE MENU_CODE = #{menuCode}) B
        WHERE
            STAT_VAL = 'Y'
          AND A.OUTPUT_MENU LIKE '%'||B.GROUP_KEY||'%'
          AND B.URL_ADR = (SELECT URL_ADR FROM NMCP_USER_MENU_BAS WHERE MENU_CODE = B.GROUP_KEY)
          AND B.URL_ADR = #{currentUrl}
          AND (
            (A.DIV_RSTRTN_TYPE='Y' AND SYSDATE BETWEEN PSTNG_START_DATE AND PSTNG_END_DATE)
                OR
            (A.DIV_RSTRTN_TYPE='N')
            )
    </select>-->

    <!--<select id="getPopupDetail"  parameterType="com.ktmmobile.mcp.common.dto.PopupDto"  resultType="com.ktmmobile.mcp.common.dto.PopupDto">
        SELECT /* CommonMapper.getPopupDetail */
            A.POPUP_SEQ
             , A.POPUP_SUBJECT
             , A.WIDTH_SIZE
             , A.HEIGHT_SIZE
             , A.XCRD
             , A.YCRD
             , A.POPUP_URL
             , A.POPUP_OPEN_STAT
             , B.POPUP_SBST
             , A.SCROLL_YN
             , A.CONTENT_TYPE
             , A.USAGE_TYPE
        FROM
            NMCP_POPUP_BAS A
            , NMCP_POPUP_EDITOR B
        WHERE
            A.POPUP_SEQ = #{popupSeq}
          AND A.STAT_VAL = 'Y'
          AND A.POPUP_SEQ = B.POPUP_SEQ (+)
          AND B.DEVICE = #{device}
    </select>-->

    <!--<select id="getPopupMainList" resultType="com.ktmmobile.mcp.common.dto.PopupDto">
        SELECT /* CommonMapper.getPopupMainList */
        POPUP_SEQ, POPUP_SUBJECT, WIDTH_SIZE, HEIGHT_SIZE, XCRD, YCRD, POPUP_URL, POPUP_OPEN_STAT
        FROM (SELECT POPUP_SEQ, POPUP_SUBJECT, WIDTH_SIZE, HEIGHT_SIZE, XCRD, YCRD, POPUP_URL, POPUP_OPEN_STAT
        , ROW_NUMBER() OVER (ORDER BY CRET_DT DESC, POPUP_SEQ DESC) AS RN
        FROM NMCP_POPUP_BAS
        WHERE STAT_VAL = 'Y'
        AND ((DIV_RSTRTN_TYPE='Y' AND SYSDATE BETWEEN PSTNG_START_DATE AND PSTNG_END_DATE)
        OR
        (DIV_RSTRTN_TYPE='N')
        )
        AND UPPER(OUTPUT_MENU) LIKE UPPER('%'||#{menuCode}||'%')
        )
        <if test="_parameter == 'SMMainWeb'.toString()">
            WHERE RN = 1
        </if>
    </select>-->

