    <!--<select id="getRateResChgList"  parameterType="com.ktmmobile.mcp.common.dto.McpIpStatisticDto"  resultType="com.ktmmobile.mcp.common.dto.McpIpStatisticDto">
        SELECT /*CommonMapper.getRateResChgList   */
        RATE_RES_CHG_SEQ
        , SVC_CNTR_NO
        , MOBILE_NO
        , USER_ID
        , EVENT_CODE
        , RES_CHG_RATE_CD
        , BEF_CHG_RATE_CD
        , BEF_CHG_RATE_AMNT
        ,PARAM
        ,RES_CHG_DATE
        ,RES_CHG_APY_DATE
        ,TRT_MDL_DIV
        ,GLOBAL_NO
        ,BATCH_RSLT_CD
        ,CRET_IP
        ,CRET_DT
        FROM
        NMCP_RATE_RES_CHG_BAS
        WHERE 1=1
        <if test="resChgApyDate != null and resChgApyDate != ''">
            AND RES_CHG_APY_DATE = #{resChgApyDate}
        </if>
        <if test="rateResChgSeq != null and rateResChgSeq != ''">
            AND RATE_RES_CHG_SEQ = #{rateResChgSeq}
        </if>
        <choose>
            <when test="batchRsltCd !=null and batchRsltCd != ''" >
                AND BATCH_RSLT_CD = #{batchRsltCd}
            </when>
            <otherwise>
                AND NVL(BATCH_RSLT_CD,'-1') = '-1'
            </otherwise>
        </choose>
        ORDER BY  RATE_RES_CHG_SEQ
    </select>-->

