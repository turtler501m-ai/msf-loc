<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ktmmobile.msf.domains.form.form.appform_d.adapter.repository.mybatis.msp.mapper.MspCdMapper">

  <select id="selectList" resultType="com.ktmmobile.msf.domains.form.form.appform_d.domain.entity.MspCd">
    SELECT
    GRP_ID
    , CD_VAL
    , CD_DSC
    , USG_YN
    FROM CMN_GRP_CD_MST
    <where>
      <if test='@org.springframework.util.StringUtils@hasText(grpId)'>
        AND GRP_ID LIKE CONCAT(#{grpId}, '%')
      </if>
      <if test='@org.springframework.util.StringUtils@hasText(usgYn)'>
        AND USG_YN LIKE CONCAT(#{usgYn}, '%')
      </if>
    </where>
    ORDER BY GRP_ID, CD_VAL
  </select>

</mapper>