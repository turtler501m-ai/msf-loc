    <select id="nextRequestKey" resultType="java.lang.Long">
        SELECT nextval('SQ_REQUEST_KEY')
    </select>

    <insert id="insertRequestCancel" parameterType="com.ktmmobile.msf.domains.form.form.termination.dto.TerminationInsertDto">
        INSERT INTO MSF_REQUEST_CANCEL (
            REQUEST_KEY,
            AGENT_CD,
            OPER_TYPE_CD,
            CSTMR_TYPE_CD,
            CANCEL_MOBILE_NO,
            CONTRACT_NUM,
            CSTMR_NM,
            RECEIVE_MOBILE_NO,
            RECEIVE_WAY_CD,
            CANCEL_USE_COMPANY_CD,
            PAY_AMT,
            PNLT_AMT,
            LAST_SUM_AMT,
            INSTAMT_MNTH_CNT,
            INSTAMT_MNTH_AMT,
            BENEFIT_AGREE_YN,
            CLAUSE_CNTR_DEL_YN,
            ETC_AGREE_YN,
            MEMO,
            REG_DATE,
            REGST_ID,
            REG_DT,
            PROC_CD,
            CRET_IP,
            CRET_ID,
            CRET_DT,
            AMD_IP,
            AMD_ID,
            AMD_DT
        ) VALUES (
            #{requestKey},
            #{agentCd},
            #{operTypeCd},
            #{cstmrTypeCd},
            #{cancelMobileNo},
            #{contractNum},
            #{cstmrNm},
            #{receiveMobileNo},
            #{receiveWayCd},
            #{cancelUseCompanyCd},
            #{payAmt},
            #{pnltAmt},
            #{lastSumAmt},
            #{instamtMnthCnt},
            #{instamtMnthAmt},
            #{benefitAgreeYn},
            #{clauseCntrDelYn},
            #{etcAgreeYn},
            #{memo},
            TO_CHAR(NOW(), 'YYYYMMDD'),
            #{regstId},
            NOW(),
            'RC',
            #{cretIp},
            #{cretId},
            NOW(),
            #{amdIp},
            #{amdId},
            NOW()
        )
    </insert>

