<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="CancelConsultMapper">
    <select id="countCancelConsult" parameterType="com.ktmmobile.mcp.mypage.dto.CancelConsultDto" resultType="int">
        SELECT COUNT(*)
        FROM MCP_CANCEL_REQUEST
        WHERE 1=1
        AND (PROC_CD IS NULL OR PROC_CD != 'BK')
        <choose>
            <when test="contractNum == 'manual'">
                <if test="cancelMobileNo != null and cancelMobileNo != ''">
                    AND CANCEL_MOBILE_NO = #{cancelMobileNo}
                </if>
            </when>
            <otherwise>
                <if test="contractNum != null and contractNum != ''">
                    AND CONTRACT_NUM = #{contractNum}
                </if>
            </otherwise>
        </choose>
    </select>

