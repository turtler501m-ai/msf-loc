<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
	
	<!-- OFF > FATAL > ERROR > WARN > INFO > DEBUG > TRACE > ALL -->
	
	<Appenders>
<!-- 		<Console name="console" target="SYSTEM_OUT"> -->
<!-- 			<PatternLayout pattern="[BATCH-LOG %d{yyyy-MM-dd HH:mm:ss}] [%5p] [%c.%M():%L] - %m%n" /> -->
<!-- 		</Console> -->
		
		<RollingFile name="logFILE" fileName="/jb_log/batch/batch.log" filePattern="/jb_log/batch/batch.log.%d{yyyy-MM-dd}">
			<PatternLayout pattern="[BATCH-LOG %d{yyyy-MM-dd HH:mm:ss}] [%5p] [%c.%M():%L] - %m%n" />
			<Policies>
				<TimeBasedTriggeringPolicy interval="1" modulate="true"/>
			</Policies>
			<DefaultRolloverStrategy max="60"/>
		</RollingFile>
		
		<RollingFile name="errlogFILE" fileName="/jb_log/batch/batch-error.log" filePattern="/jb_log/batch/batch-error.log.%d{yyyy-MM-dd}">
			<PatternLayout pattern="[BATCH-LOG %d{yyyy-MM-dd HH:mm:ss}] [%5p] [%c.%M():%L] - %m%n" />
			<Policies>
				<TimeBasedTriggeringPolicy interval="1" modulate="true"/>
			</Policies>
			<DefaultRolloverStrategy max="60"/>
		</RollingFile>
		
	</Appenders>
	
	
	
	<Loggers>
		<Logger name="egovframework" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Logger>
		
		<Logger name="org.springframework" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Logger>
		
		<logger name="org.springframework.beans.factory.xml.PluggableSchemaResolver"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="org.springframework.core.io.support.PathMatchingResourcePatternResolver"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="org.springframework.context.annotation.ClassPathBeanDefinitionScanner"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="org.springframework.aop.framework.CglibAopProxy"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		
		<logger name="org.springframework.web.servlet.mvc.method.annotation.RequestResponseBodyMethodProcessor"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerMapping"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="org.springframework.beans.factory.support.DefaultListableBeanFactory"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		
		<logger name="org.springframework.beans.factory.support.DefaultListableBeanFactory"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="org.springframework.jdbc.datasource.DataSourceTransactionManager"
				level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		
		
		
		<logger name="java.sql.Connection" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<logger name="java.sql.ResultSet" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		<Logger name="java.sql.PreparedStatement" level="DEBUG"
				additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Logger>
		
		
		
		<Logger name="java.sql.Statement" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Logger>
		
		<Logger name="org.apache.commons.digester.Digester" level="ERROR"
				additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Logger>
		
		
		<Logger name="org.mybatis" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Logger>
		<logger name="org.mybatis.spring.mapper.ClassPathMapperScanner" level="ERROR" additivity="false">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</logger>
		
		<Root level="INFO">
<!-- 			<AppenderRef ref="console" /> -->
			<AppenderRef ref="logFILE" />
			<AppenderRef ref="errlogFILE" level="ERROR"/>
		</Root>
		
	</Loggers>
	
</Configuration>
