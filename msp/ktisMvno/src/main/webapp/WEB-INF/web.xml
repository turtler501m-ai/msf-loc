<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://java.sun.com/xml/ns/javaee" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd" version="3.0">
  <display-name>MVNO SALES Portal</display-name>
  
		
  <!-- Spring Dispatcher Servlet  -->
  <servlet>
    <servlet-name>SpringDispatcherServlet</servlet-name>
    <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
    <init-param>
      <param-name>contextConfigLocation</param-name>
      <param-value>
				/WEB-INF/config/egovframework/springmvc/dispatcher-servlet.xml,
				/WEB-INF/config/egovframework/springmvc/urlfilename-servlet.xml
			</param-value>
    </init-param>
    <load-on-startup>1</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>SpringDispatcherServlet</servlet-name>
    <url-pattern>*.do</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>SpringDispatcherServlet</servlet-name>
    <url-pattern>*.xml</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
    <servlet-name>SpringDispatcherServlet</servlet-name>
    <url-pattern>*.json</url-pattern>
  </servlet-mapping>
  
  
  <context-param>
    <param-name>contextConfigLocation</param-name>
    <param-value>classpath*:egovframework/spring/context-*.xml</param-value>
  </context-param>

  <listener>
    <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
  </listener>
  <listener>
    <listener-class>org.springframework.security.web.session.HttpSessionEventPublisher</listener-class>
  </listener>
  
  <!-- Filter -->
  <filter>
    <filter-name>encodingFilter</filter-name>
    <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>
    <init-param>
      <param-name>encoding</param-name>
      <param-value>utf-8</param-value>
    </init-param>
  </filter>
  <filter>
    <filter-name>HTMLTagFilter</filter-name>
    <filter-class>egovframework.rte.ptl.mvc.filter.HTMLTagFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>encodingFilter</filter-name>
    <url-pattern>*.do</url-pattern>
  </filter-mapping>
  <!--  20140905 add by jungman-->
  <filter-mapping>
    <filter-name>encodingFilter</filter-name>
    <url-pattern>*.json</url-pattern>
  </filter-mapping>
  
  <filter-mapping>
    <filter-name>HTMLTagFilter</filter-name>
    <url-pattern>*.do</url-pattern>
  </filter-mapping>
  
  



	<!-- UBreport -->
	<servlet>
		<servlet-name>UbiForm</servlet-name>
		<servlet-class>com.ubidcs.report.gateway.UbiForm</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>UbiData</servlet-name>
		<servlet-class>com.ubidcs.report.gateway.UbiData</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>UbiAdmin</servlet-name>
		<servlet-class>com.ubidcs.report.gateway.UbiAdmin</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>UbiGateway</servlet-name>
		<servlet-class>com.ubidcs.report.gateway.UbiGateway</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>UbiServer</servlet-name>
	    <servlet-class>com.ubireport.server.UbiServer4Token</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>UbiForm</servlet-name>
		<url-pattern>/UbiForm</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>UbiData</servlet-name>
		<url-pattern>/UbiData</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>UbiAdmin</servlet-name>
		<url-pattern>/UbiAdmin</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>UbiGateway</servlet-name>
		<url-pattern>/UbiGateway</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>UbiServer</servlet-name>
		<url-pattern>/UbiServer</url-pattern>
	</servlet-mapping>
	<!-- //UBreport -->

  <!-- Welcome Page -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
  
  
  <login-config>
    <auth-method>BASIC</auth-method>
  </login-config>
  
  <!-- Error Page -->
  <error-page>
    <exception-type>java.lang.Throwable</exception-type>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>400</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>401</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>403</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>404</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>405</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  <error-page>
    <error-code>501</error-code>
    <location>/WEB-INF/jsp/ktis/base/error.html</location>
  </error-page>
  
	<session-config>
 		<session-timeout>60</session-timeout>
 		<cookie-config>
 			<secure>true</secure>
 			<http-only>true</http-only>
 		</cookie-config>
		<tracking-mode>COOKIE</tracking-mode>
	</session-config>
	
	<security-constraint>
		<display-name>HTTP Method deactivate</display-name>
		<web-resource-collection>
			<web-resource-name>Forbidden HTTP Method</web-resource-name>
			<url-pattern>/*</url-pattern>
			<http-method>PUT</http-method>
			<http-method>DELETE</http-method>
			<http-method>OPTIONS</http-method>
			<http-method>TRACE</http-method>
		</web-resource-collection>
		<auth-constraint>
			<role-name></role-name>
		</auth-constraint>
	</security-constraint>
	<distributable/>
</web-app>