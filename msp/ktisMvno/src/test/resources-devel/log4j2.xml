<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <Console name="console" target="SYSTEM_OUT">
            <PatternLayout pattern="[ [KTIS-LOG] [%5p] [%c{1}.%M():%L] - %m%n" />
        </Console>
    </Appenders>
    <Loggers>
        <Logger name="egovframework" level="INFO" additivity="false">
        	<level value="INFO" />
        	<AppenderRef ref="console" />
        </Logger>
	
        <Root level="ERROR">
            <AppenderRef ref="console" />
        </Root>
    </Loggers>
</Configuration>
