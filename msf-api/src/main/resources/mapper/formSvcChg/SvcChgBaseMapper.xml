<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktmmobile.msf.formSvcChg.mapper.SvcChgBaseMapper">

    <!--
        서비스변경 업무 카테고리 목록 조회.
        MSF_CD_GROUP_BAS 테이블 (스마트서식지 자체 코드 관리).
    -->
    <select id="selectSvcChgCategories"
            resultType="com.ktmmobile.msf.formSvcChg.dto.SvcChgBaseCategoryDto">
        SELECT
            GROUP_CD    AS groupCd,
            GROUP_NM    AS groupNm,
            SVC_TGT_CD  AS svcTgtCd,
            SORT_SEQ    AS sortSeq
        FROM MSF_CD_GROUP_BAS
        WHERE USE_YN = 'Y'
        ORDER BY SORT_SEQ
    </select>

    <!--
        카테고리별 상세 옵션 목록 조회.
        MSF_CD_DTL 테이블.
    -->
    <select id="selectSvcChgOptions"
            parameterType="map"
            resultType="com.ktmmobile.msf.formSvcChg.dto.SvcChgBaseOptionDto">
        SELECT
            DTL_CD              AS dtlCd,
            DTL_CD_NM           AS dtlCdNm,
            CONCURRENT_BLOCK_YN AS concurrentBlockYn,
            IMAGING_YN          AS imagingYn,
            SORT_SEQ            AS sortSeq
        FROM MSF_CD_DTL
        WHERE GROUP_CD = #{groupCd}
          AND USE_YN   = 'Y'
        ORDER BY SORT_SEQ
    </select>

</mapper>
