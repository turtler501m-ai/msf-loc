<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

<!-- 	<bean id="sqlSessionFactory" class="org.mybatis.spring.SqlSessionFactoryBean"> -->
<!-- 	  	<property name="dataSource" ref="dataSource"/> -->
<!-- 	  	<property name="configLocation" value="classpath:/com.ktis.mcpif/sqlmap/sql-mapper-config.xml" /> -->
<!-- 		<property name="mapperLocations" value="classpath*:com.ktis.mcpif/sqlmap/**/*/*_SQL.xml"/> -->
<!-- 	</bean> -->


	<bean id="sqlSessionFactory" class="org.mybatis.spring.SqlSessionFactoryBean">
        <property name="dataSource" ref="dataSource"/>
<!--         <property name="configLocation" value="classpath:/com.ktis.mcpif/sqlmap/sql-mapper-config.xml" /> -->
      <property name="configLocation" value="classpath:/com/ktis/mcpif/sqlmap/sql-mapper-config.xml" />
      <property name="mapperLocations" value="classpath*:com/ktis/mcpif/sqlmap/**/*/*_SQL.xml"/>
   </bean>


	<bean id="ktisMapper" class="org.mybatis.spring.mapper.MapperScannerConfigurer">
		<property name="basePackage" value="com.ktis.mcpif.*.*.mapper" />
		<property name="sqlSessionFactoryBeanName" value="sqlSessionFactory" />
	</bean>

	<bean id="sqlSession" class="org.mybatis.spring.SqlSessionTemplate">
		<constructor-arg ref="sqlSessionFactory"/>
	</bean>
</beans>