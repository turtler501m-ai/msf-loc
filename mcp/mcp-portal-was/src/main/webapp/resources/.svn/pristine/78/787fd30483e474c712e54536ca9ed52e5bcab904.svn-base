.background_wide_top{width:100%;border-bottom:3px solid #ed1c24;background:white;min-width: 1000px;}
.background_wide_gray{width:100%;background:#f9f9f9;padding:50px 0 50px 0}

.content{max-width:1000px;width:1000px;margin:0 auto 0 auto;display: flex;justify-content: space-around;box-sizing:border-box}
.content2{max-width:1000px;width:1000px;margin:0 auto 0 auto;margin-top:30px;}

.header{max-width:1000px; width:100%; margin:0 auto 0 auto;padding:15px 0;background:white; font-family:"KT-sans", "Spoqa Han Sans", "Spoqa Han Sans Neo", "Spoqa Han Sans JP", "Source Sans Pro", Apple SD Gothic Neo, Nanum Barun Gothic, Nanum Gothic, "돋움", Dotum, Verdana, Arial, sans-serif;}
.header:after{clear:both;content:"";display: block}
.header .logo{float:left;}
.header .logo img{height:50px;}
.header .gnb{float: left; margin-left: 100px; position: relative}
.header .gnb ul{padding:0;margin:0;list-style: none;margin-top:13px;}
.header .gnb ul:after{clear:both;content:"";display:block}
.header .gnb ul li{float:left;margin-left:88px;font-size:18px;font-weight: bold;}
.header .gnb ul li:hover{color:#ed1c24;cursor:pointer}
.header .gnb ul li:last-child{margin-left: 150px;}
.header .sub_menu{position: absolute;width:100%;border:0px solid #ed1c24;box-sizing: border-box;background:white;left:0;top:82px;box-sizing: border-box;border-top:1px solid #d3d3d3;border-bottom:1px solid #d3d3d3;padding-bottom:30px;display:none; z-index: 1000; font-size: 14px;}
.header .sub_menu .menu_item{color:#666;list-style:none;float: left;padding:0;margin:0;margin-left:115px;line-height: 1.5em;}
.header .sub_menu .menu_item:first-child{margin-left:350px;}
.header .sub_menu .menu_item:last-child{margin-left:115px;}
.header .sub_menu:after{clear:both;content:"";display: block;}
.header .sub_menu .menu_item li:hover{color:#ed1c24;cursor:pointer}

.gnb_mobile{display:none;}
.sub_menu_mobile{display:none;}

.header .gnb ul li button{height:40px;border-radius:20px;border:1px solid #ed1c24;width:150px;background:white;font-weight: bold;color:#ed1c24;margin-top:-10px; font-family:"KT-sans", "Spoqa Han Sans", "Spoqa Han Sans Neo", "Spoqa Han Sans JP", "Source Sans Pro", Apple SD Gothic Neo, Nanum Barun Gothic, Nanum Gothic, "돋움", Dotum, Verdana, Arial, sans-serif;}
.header .gnb ul li button:hover{border:1px solid #ed1c24;background:#ed1c24;font-weight: bold;color:white;}

.footer{font-size:12px;color: #666;text-align: left;display:block;margin-top:1px solid #d3d3d3;}
.footer .logo2{float:right;margin-top:-30px;margin-right:20px;}




.ly-content {
    width: 100%;
    color: #111;
    border-bottom: 0.0625rem solid #d3d3d3;
    background: #fff;
    line-height: 1.38;
    font-size: 1rem; }

.content-wide {
    width: 100%;
    background-color: #f7f7f7; }

.content-wide .content-section {
	position: relative;
	width: 62.5rem;
	margin: 0 auto;
    -webkit-box-flex: 1;
    -ms-flex: 1 0 auto;
    flex: 1 0 auto;
    padding: 5rem 0; }

.content-section {
	position: relative;
	width: 62.5rem;
	margin: 0 auto;
    -webkit-box-flex: 1;
    -ms-flex: 1 0 auto;
    flex: 1 0 auto;
    padding: 7.5rem 0; }

.content-section:first-child {
	padding-top: 6.25rem;	}

.content-wrap {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -webkit-box-pack: justify;
    -ms-flex-pack: justify;
    justify-content: space-between; }

.content__tit {
    margin-top: -0.375rem;
	letter-spacing: -0.04rem;
    font-weight: 700;
    font-size: 2rem; }

.content__box {
    position: relative;
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    flex-wrap: wrap;
    width: 46.875rem; }

.recruit-ideal-wrap {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-wrap: wrap;
    flex-wrap: wrap; }

.recruit-ideal__item {
	position: relative;
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -webkit-box-direction: normal;
    -ms-flex-direction: column;
    flex-direction: column;
    align-items: center;
    padding: 2.50rem;
    width: 22.1875rem;
    min-height: 19.6875rem;
    background-color: #f7f7f7; }
.recruit-ideal__item:nth-of-type(2n) {
	margin-left: 2.5rem; }
.recruit-ideal__item:nth-of-type(n+3) {
	margin-top: 2.5rem; }

.recruit-ideal__item.bg-point{
	background-color: #fff3f3; }

.recruit-ideal__item .recruit-ideal-img {
	display: block; }

.recruit-ideal__item .recruit-ideal-m-img {
    width: 4.125rem;
	display: none; }

.recruit-ideal__txt {
	margin: 1.25rem 0 1.625rem;
    text-align: center;
	letter-spacing: -0.023rem;
    font-weight: 700;
    font-size: 1.375rem; }

.recruit-ideal__txtlist {
	letter-spacing: -0.031rem;
	color: #333; }
.recruit-ideal__txtlist li {
	position: relative;
	margin-top: 0.625rem;
    padding-left: 0.625rem;     }

.recruit-ideal__txtlist li:first-child {
	margin-top: 0; }

.recruit-ideal__txtlist li::before {
    content: '';
    display: block;
    clear: both;
    position: absolute;
    top: 0.4375rem;
    left: 0;
    width: 0.1875rem;
    height: 0.1875rem;
    border-radius: 50%;
    background: #555; }

.recruit-ideal-wrap .bg-img{
    position: absolute;
    right: -7.8125rem;
    bottom: -8rem;
    z-index: 2; }

.recruit-person-wrap {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-wrap: wrap;
    flex-wrap: wrap; }

.recruit-person__item {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -webkit-box-direction: normal;
    -ms-flex-direction: column;
    flex-direction: column;
    width: 22.1875rem; }
.recruit-person__item:nth-of-type(2n) {
	margin-left: 2.5rem; }
.recruit-person__item:nth-of-type(n+3) {
	margin-top: 2.5rem; }

.recruit-person__tit {
	margin-top: -0.25rem;
	margin-bottom: 1rem;
	color: #222;
    letter-spacing: -0.025rem;
    font-weight: 700;
    font-size: 1.25rem; }

.recruit-person__txt {
	color: #333;
    letter-spacing: -0.031rem;
    font-size: 1rem;
    text-align: justify; }

.recruit-welfarel-wrap {
	border-top: 0.0625rem solid #dedede; }

.recruit-welfarel-box {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-wrap: wrap;
    flex-wrap: wrap;
    padding: 1.75rem 0;
    border-bottom: 0.0625rem solid #dedede;}

.recruit-welfarel-tit {
	margin-top: -0.25rem;;
    margin-bottom: 1.375rem;
    color: #f12931;
    letter-spacing: -0.025rem;
    font-weight: 500;
    font-size: 1.25rem; }

.recruit-welfarel-list {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-wrap: wrap;
    flex-wrap: wrap; }

.recruit-welfarel__item {
	display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    align-items: center;
    width: 22.1875rem; }
.recruit-welfarel__item:nth-of-type(2n) {
	margin-left: 2.5rem; }
.recruit-welfarel__item:nth-of-type(n+3) {
	margin-top: 0.75rem; }

.recruit-welfarel__item img {
	margin-right: 1.375rem; }

.recruit-welfarel-list__tit {
	margin-top: 0.125rem;
	margin-bottom: 0.25rem;
	color: #222;
    letter-spacing: -0.029rem;
    font-weight: 500;
    font-size: 1.0625rem; }

.recruit-welfarel-list__txt {
	color: #575757;
    letter-spacing: -0.033rem;
    font-size: 0.9375rem; }


.recruit-person-img {
	display: block;
	position: relative; }

.recruit-person-m-img {
	display: none;
	position: relative; }

.recruit-person-m-img p {
    position: absolute;
    left: 50%;
    top: 50%;
    -webkit-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%);
    color: #fff;
    text-align: center;
    letter-spacing: -0.028rem;
    font-weight: 700;
   	font-size: 1.25rem;
  	text-shadow: 0 0 0.5rem rgb(0 0 0); }


/* 미디어쿼리 시작 */
@media (max-width: 720px){

	.ly-content {
		padding: 0 2rem; }

	.content-section {
	    width: 100%;
	    padding: 5rem 0;	}

	.content-section:first-child {
		padding-top: 3.125rem; }

	.content-wrap {
	    -webkit-box-direction: normal;
	    -ms-flex-direction: column;
	    flex-direction: column; }

	.content__tit {
	    margin-bottom: 2rem;
	    text-align: center;
        letter-spacing: -0.02rem;
	    font-size: 1.5rem; }

    .content__box {
	    width: 100%;
	    padding-top: 2rem;
    border-top: 0.0625rem solid #dedede; }

    .recruit-ideal__item {
	    padding: 0;
	    width: 100%;
	    height: auto;
        min-height: auto;
    	background-color: #fff;	}
    .recruit-ideal__item:nth-of-type(2n) {
		margin-top: 3rem;
	    margin-left: 0; }
	.recruit-ideal__item:nth-of-type(n+3) {
	    margin-top: 0; 	}
  	.recruit-ideal__item:nth-of-type(n+2) {
		margin-top: 3rem; }

	.recruit-ideal__item.bg-point {
	    background-color: #fff; }

  .recruit-ideal__item .recruit-ideal-img {
		display: none; }

	.recruit-ideal__item .recruit-ideal-m-img {
		display: block; }

	.recruit-ideal-wrap .bg-img {
       display: none; }

	.recruit-ideal__txt {
		margin-bottom: 1.25rem;
		letter-spacing: -0.031rem;
	    font-size: 1.125rem; }

	.recruit-ideal__txtlist {
	    margin-right: auto; }

   	.recruit-ideal__txtlist li {
  	 	letter-spacing: -0.038rem;
   		font-size: 0.8125rem;
	    padding-left: 0.375rem; }

   	.recruit-ideal__txtlist li::before {
    	top: 0.375rem; }

   	.content-wide {
	    width: auto;
	    margin-left: -2rem !important;
	    margin-right: -2rem !important; }

	.content-wide .content-section {
		position: relative;
		width: 100%;
	    padding: 3rem 2rem 0; }

	.content-wide .content__tit {
		margin-bottom: 2.5rem;
        letter-spacing: -0.02rem;}

    .content-wide .content__box {
    	padding-top: 0;
	    border-top: none; }

    .recruit-person__item {
	    width: 100%; }

   	.recruit-person__item img {
	    max-width: 100%;
	    height: auto; }

   	.recruit-person__item:nth-child(3 ){
   		margin-bottom: 0;
		order: 2; }

	.recruit-person__item:nth-of-type(2n) {
	    margin-left: 0;	}
	.recruit-person__item:nth-of-type(n+3) {
		margin-top: 0; }

    .recruit-person-img {
		display: none; }

	.recruit-person-m-img {
		display: block; }

	.recruit-person__tit {
		display: none; }

	.recruit-person__txt {
	    margin-top: 1.5rem;
    	margin-bottom: 3rem;
    	letter-spacing: -0.038rem;
    	font-size: 0.8125rem; }

   	.recruit-welfarel-wrap {
	    border-top: none; }

	.recruit-welfarel-box {
        -webkit-box-direction: normal;
    	-ms-flex-direction: column;
    	flex-direction: column;
	    padding: 2rem 0;	}

    .recruit-welfarel-box:first-child {
	    padding-top: 0; }

	.recruit-welfarel__item {
   	    width: 100%; }

	.recruit-welfarel__item:nth-of-type(2n) {
	    margin-left: 0; }

    .recruit-welfarel__item:nth-of-type(n+2) {
		margin-top: 0.75rem; }

	.recruit-welfarel-tit {
	    margin-bottom: 1.25rem;
	    font-weight: 700;
	    text-align: center;
	    font-size: 1rem; }

    .recruit-welfarel__item img {
    	width: 2.25rem;
	    margin-right: 1rem; }

    .recruit-welfarel-list__tit {
    	margin-bottom: 0.125rem;
    	letter-spacing: -0.038rem;
	    font-size: 0.8125rem; }

    .recruit-welfarel-list__txt {
	    letter-spacing: -0.04rem;
	    font-size: 0.75rem; }


	.header{max-width:1000px; width:100%; margin:0 auto 0 auto;padding:10px 0 10px 0;background:white;z-index:999;border-bottom:1px solid #d3d3d3;}
    .logo{display: none;}
    .gnb{display: none;}

	.content{max-width:1000px;width:100%;margin:0 auto 0 auto;display:block;}
    .content2{padding-left:15px; padding-right:15px;box-sizing: border-box;width:100%;}

    .gnb_mobile{display:block;text-align: center;border-bottom:0px solid #d3d3d3;background:white;top:0;left}
    .gnb_mobile .menu{position: absolute; top: 0.625rem; right: 1.25rem;}
    .gnb_mobile img{height:20px;}
    .sub_menu_mobile{z-index:1000;display:none;position: absolute;background:white;width:100%;text-align: center;font-size:12px;font-weight: bold;box-shadow: 0 5px 5px rgba(0,0,0,0.3)}
    .sub_menu_mobile ul{list-style: none;padding:0;margin:0;border-top:1px solid #d3d3d3;margin-top:10px;}
    .sub_menu_mobile ul li{padding:10px;border-bottom:1px solid #d3d3d3;}
    .banner{width:100%;height:auto;background:url(/resources/company/img/banner1.jpg);background-position-x: 50%; background-position-y: 50%;background-repeat: no-repeat;margin-top:0px;background-size:auto 100%}
    .background_wide_top{width:100%; min-width:320px; border-bottom:0px solid #ed1c24;background:white;}


	.background_wide_gray{padding:20px 0 20px 0;}
	.footer{padding-left:20px;padding-right:20px;box-sizing: border-box;font-size:11px;}
	.footer .logo2{float:none;margin-top:10px}
	.footer .logo2 img{height:20px;}
	.footer{margin-top:1px solid #d3d3d3;}

}/* 미디어쿼리 끝 */








