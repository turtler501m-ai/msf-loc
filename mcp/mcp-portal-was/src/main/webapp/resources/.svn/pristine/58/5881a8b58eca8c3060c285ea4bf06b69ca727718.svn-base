#layerContent {}
#layerContent .layer {display:none;position:fixed;_position:absolute;top:0;left:0;width:100%;height:100%;z-index:100;background:white}
#layerContent .layer .content_title {box-sizing:border-box;font-size:16px;text-align:center;border-top:1px solid #cbcbcb;border-bottom:1px solid #cbcbcb;height:45px;line-height:45px;vertical-align:middle;position:relative}
#layerContent .layer .content_title img {width:19px;height:19px;position:absolute;right:13px;top:11px}
#layerContent .layer .content_main {padding:15px 15px 30px 15px}
#layerContent .layer .layer_table_title {font-size:12px;text-align:left;padding-bottom:10px;border-bottom:1px solid #000}
#layerContent .layer .button_area {padding-top:20px;text-align:center}
#layerContent .layer .sample_layer {}
#layerContent .layer .pop_privacy {box-sizing:border-box;width:100%}
#layerContent .layer .pop_privacy .notice {border:1px solid #ededed;background:#f9f9f9;color:#333;padding:5px;font-size:10px;line-height:14px}
#layerContent .layer .pop_privacy .policy_title {font-size:14px;margin-top:20px;padding-bottom:5px}
#layerContent .layer .pop_privacy .policy_title:after {content:"";display:block;clear:both}
#layerContent .layer .pop_privacy .policy_title label {float:right;font-size:12px}
#layerContent .layer .pop_privacy .policy {box-sizing:border-box;width:100%;border:1px solid #d3d3d3;height:100px;overflow:auto;padding:5px}
#layerContent .layer .pop_privacy .addinfo_title {font-size:14px;margin-top:20px;padding-bottom:5px;text-align:left}
#layerContent .layer .pop_privacy .addinfo {}
#layerContent .layer .pop_privacy .addinfo table {width:100%;border-collapse:collapse;border-top:1px solid #ededed}
#layerContent .layer .pop_privacy .addinfo table tr th {background:#f9f9f9;color:#666;font-weight:normal;border-bottom:1px solid #ededed;text-align:left;vertical-align:middle;padding-left:10px}
#layerContent .layer .pop_privacy .addinfo table tr td {border-bottom:1px solid #ededed;padding:5px 5px;text-align:left}
#layerContent .layer .pop_privacy .addinfo table tr td label {float:left;margin-right:5px}
#layerContent .layer .pop_privacy .buttonlist {padding-top:20px}
#layerContent .layer .pop_privacy .buttonlist .btn_ok {padding:7px 0;background:#ed1c24;color:white;border:1px solid #8c1217;width:100%;font-size:14px;font-weight:bold}
#layerContent .layer .pop_tranferee {padding:15px;}
#layerContent .layer .pop_tranferee .form {margin-bottom:15px}
#layerContent .layer .pop_tranferee .form .form_title {padding:10px 0;font-weight:bold}
#layerContent .layer .pop_tranferee .button_area {margin-top:30px;margin-bottom:30px}
#layerContent .layer .pop_tranferee .button_area button:first-child {width:48%;float:left}
#layerContent .layer .pop_tranferee .button_area button:last-child {width:48%;float:right}
#layerContent .layer .pop_tranferee .button_area:after {clear:both;content:"";display:block}
#layerContent .layer .select_language {width:100%;text-align:center}
#layerContent .layer .select_language .language_item {width:100%;display:table;border-bottom:1px solid #ededed}
#layerContent .layer .select_language .language_item .flag {padding:15px;width:50px;display:table-cell;line-height:20px;vertical-align:middle}
#layerContent .layer .select_language .language_item .flag img {width:30px;height:30px}
#layerContent .layer .select_language .language_item .text {padding:15px;display:table-cell;text-align:left;line-height:20px;vertical-align:middle}
#layerContent .layer .select_language .language_item .button {padding:15px;width:50px;display:table-cell;line-height:20px;vertical-align:middle}
#layerContent .layer .btn_area {margin-top:30px;text-align:center}
#layerContent .layer .layer_title_on{ height:40px; border-bottom:1px solid #d4d4d4; display: table; width: 100%;background: url(../../images/company/menu_arrow_up.png) no-repeat 95%; background-size: 13px 8px;}
#layerContent .layer .layer_title_off{ height:40px; border-bottom:1px solid #d4d4d4; display: table; width: 100%;background: url(../../images/company/menu_arrow_down.png) no-repeat 95%; background-size: 13px 8px;}
#layerContent .layer .lt_title{vertical-align:middle; font-size: 12px; font-weight:bold; display: table-cell;}
#layerContent .layer .layer_contets{}
#layerContent .layer .layer_contets .lc_box{width:100%;box-sizing:border-box;display:table;*display:block; height: 30px; border-bottom: 1px solid #d4d4d4; padding: 0 15px; background-color: #f9f9f9;}
#layerContent .layer .layer_contets .lc_box .lcb_cont{box-sizing:border-box;display:table-cell;vertical-align:middle;*float:left; width: 80%;}
#layerContent .layer .layer_contets .lc_box .lcb_check{box-sizing:border-box;display:table-cell;vertical-align:middle;*float:right; width: 20%; text-align: right;}
#layerContent .layer #clauseContents {padding:15px;border:1px solid #ededed}
#layerContent .layer #scrollArea {}
#layerContent .layer #divLayer2 {}
#layerContent .layer .farPricePlan .notice_sub2 {box-sizing:border-box;font-size:12px;color:#000;padding:0 0 15px 15px;background-image:url(../../images/company/icon_blog_order_active.png);background-repeat:no-repeat;background-position:0px 7px}
#layerContent .layer .farPricePlan .jejuair_agree {border-top:0;margin-bottom:10px}
#layerContent .layer .farPricePlan .jejuair_agree table tr th {vertical-align:top}
#layerContent .layer .farPricePlan .jejuair_agree table tr td {text-align:left;padding-left:10px;padding-right:10px}
#layerContent .layer .farPricePlan .jejuair_agree ul {margin:0;padding:0;margin-left:15px}
#layerContent .layer .farPricePlan .jejuair_agree ul li {list-style:disc;margin-bottom:5px}
#layerContent .layer .farPricePlan .jejuair_agree .agree_title {box-sizing:border-box;padding:15px 10px;background:#f9f9f9;border-bottom:1px solid #ededed;font-size:16px;color:#000}
#layerContent .layer .farPricePlan .jejuair_agree .agree_content {box-sizing:border-box;height:90px;overflow:auto;padding:20px 15px 5px 15px}
#layerContent .layer .farPricePlan label {font-size:12px;color:#000}
#layerContent .layer .newversion .message {text-align:center;font-size:16px;font-weight:bold;padding-top:150px;line-height:150%}
#layerContent .layer .newversion .button_area {padding-top:50px;text-align:center}
#layerContent .layer .newversion .button_area button {font-size:13px;border:1px solid #8c1217;background:#ed1c24;color:white;box-sizing:border-box;padding:6px 20px;height:48px;font-weight:bold}
#layerContent .layer .content_main .appform_cancel .cancel_title {font-size:18px;line-height:150%;padding-bottom:15px;border-bottom:1px solid #000}
#layerContent .layer .content_main .appform_cancel .cancel_step {display:table;border-collapse:collapse;width:100%}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item {display:table-row;border-bottom:1px solid #d3d3d3}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item:last-child {border:0}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_number {display:table-cell;width:15px;padding:20px 0}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_number img {vertical-align:top}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_content {display:table-cell;padding:20px 0 20px 5px}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_content .step_title {font-size:15px;font-weight:bold;padding-bottom:10px}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_content .step_desc {padding-bottom:8px;font-size:14px}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_content .step_check {font-size:14px}
#layerContent .layer .content_main .appform_cancel .cancel_step .step_item .step_content .step_check img {height:12px;margin-right:7px}
#layerContent .layer .content_main .appform_cancel .button_area {padding:0;padding-bottom:75px}
#layerContent .layer .content_main .appform_cancel .button_area button {float:left;padding:0}
#layerContent .layer .content_main .appform_cancel .button_area .btn_medium_darkgrey {margin-left:10%}

