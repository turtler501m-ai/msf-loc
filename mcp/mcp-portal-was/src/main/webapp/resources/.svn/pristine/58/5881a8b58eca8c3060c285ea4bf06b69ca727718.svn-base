.background_wide_top{width:100%;border-bottom:3px solid #ed1c24;background:white;min-width: 1000px;}
.background_wide{width:100%;padding:50px 0 50px 0;background:white;min-width: 1000px;}
.background_wide2{width:100%;padding:0;min-width: 1000px;}
.background_wide_gray{width:100%;background:#f9f9f9;padding:50px 0 50px 0}

.header{max-width:1000px; width:100%; margin:0 auto 0 auto;padding:15px 0;background:white; font-family:"KT-sans", "Spoqa Han Sans", "Spoqa Han Sans Neo", "Spoqa Han Sans JP", "Source Sans Pro", Apple SD Gothic Neo, Nanum Barun Gothic, Nanum Gothic, "돋움", Dotum, Verdana, Arial, sans-serif;}
.header:after{clear:both;content:"";display: block}
.header .logo{float:left;}
.header .logo img{height:50px;}
.header .gnb{float: left; margin-left: 100px; position: relative}
.header .gnb ul{padding:0;margin:0;list-style: none;margin-top:13px;}
.header .gnb ul:after{clear:both;content:"";display:block}
.header .gnb ul li{float:left;margin-left:88px;font-size:18px;font-weight: bold;}
.header .gnb ul li:hover{color:#ed1c24;cursor:pointer}
.header .gnb ul li:last-child{margin-left: 150px;}
.header .sub_menu{position: absolute;width:100%;border:0px solid #ed1c24;box-sizing: border-box;background:white;left:0;top:82px;box-sizing: border-box;border-top:1px solid #d3d3d3;border-bottom:1px solid #d3d3d3;padding-bottom:30px;display:none; z-index: 1000; font-size: 14px;}
.header .sub_menu .menu_item{color:#666;list-style:none;float: left;padding:0;margin:0;margin-left:115px;line-height: 1.5em;}
.header .sub_menu .menu_item:first-child{margin-left:350px;}
.header .sub_menu .menu_item:last-child{margin-left:115px;}
.header .sub_menu:after{clear:both;content:"";display: block;}
.header .sub_menu .menu_item li:hover{color:#ed1c24;cursor:pointer}


.gnb_mobile{display:none;}

.sub_menu_mobile{display:none;}

.header .gnb ul li button{height:40px;border-radius:20px;border:1px solid #ed1c24;width:150px;background:white;font-weight: bold;color:#ed1c24;margin-top:-10px; font-family:"KT-sans", "Spoqa Han Sans", "Spoqa Han Sans Neo", "Spoqa Han Sans JP", "Source Sans Pro", Apple SD Gothic Neo, Nanum Barun Gothic, Nanum Gothic, "돋움", Dotum, Verdana, Arial, sans-serif;}
.header .gnb ul li button:hover{border:1px solid #ed1c24;background:#ed1c24;font-weight: bold;color:white;}
.content{max-width:1000px;width:1000px;margin:0 auto 0 auto;display: flex;justify-content: space-around;box-sizing:border-box}
.link_area{padding-top:20px;padding-bottom:20px;border-bottom:1px solid #d3d3d3;border-top:1px solid #d3d3d3;}
.link_area:after{display:block;clear:both;content:"";}
.link_area .item{float:left;cursor:pointer;margin-left: 12%}
.link_area .item:first-child{margin-left: 0;}
.link_area .link1 .img{width:100px;height:100px;background:url(/resources/company/img/icon1.png);background-repeat: no-repeat;background-position-x: 50%; background-position-y: 50%;border:1px solid #d3d3d3; border-radius: 60px;}
.link_area .link2 .img{width:100px;height:100px;background:url(/resources/company/img/icon2.png);background-repeat: no-repeat;background-position-x: 50%; background-position-y: 50%;border:1px solid #d3d3d3; border-radius: 60px;}
.link_area .link3 .img{width:100px;height:100px;background:url(/resources/company/img/icon3.png);background-repeat: no-repeat;background-position-x: 50%; background-position-y: 50%;border:1px solid #d3d3d3; border-radius: 60px;}
.link_area .link4 .img{width:100px;height:100px;background:url(/resources/company/img/icon4.png);background-repeat: no-repeat;background-position-x: 50%; background-position-y: 50%;border:1px solid #d3d3d3; border-radius: 60px;}
.link_area .link5 .img{width:100px;height:100px;background:url(/resources/company/img/icon5.png);background-repeat: no-repeat;background-position-x: 50%; background-position-y: 50%;border:1px solid #d3d3d3; border-radius: 60px;}
.link_area .item .text{width:100px;height:40px;font-weight: bold;text-align: center;margin-top:10px;color:#4f4f4f}
.link_area .item .img:hover{border:1px solid #ed1c24;}
.content .item2{width:33%;padding:40px 10px 20px 10px;box-sizing: border-box;cursor:pointer;float: left;}
.content .item2 .text{min-height: 165px;}
.content:after{display:block;clear:both;content:"";}
.content .intro .img{background:url(/resources/company/img/co1.jpg);width:100%;height:198px;text-align: center;line-height: 198px;font-size:18px;font-weight: bold;color:white;border:1px solid #d3d3d3;border-bottom:0;}
.content .intro .text{font-size:14px;text-align: justify;padding:25px;border:1px solid #d3d3d3;border-top:0; letter-spacing: -1px;position:relative;text-align:center;}
.content .intro .text button{background:white;border:1px solid #ed1c24;height:40px;border-radius:20px;width:150px;color:#ed1c24;font-weight: bold;position: relative;margin-top:20px;margin:20px auto 0 auto;}
.content .business .img{background:url(/resources/company/img/co2.jpg);width:100%;height:198px;text-align: center;line-height: 198px;font-size:18px;font-weight: bold;color:white;}
.content .business .text{text-align:center;font-size:14px;text-align: justify;padding:25px;border:1px solid #d3d3d3;border-top:0;text-align:center;}
.content .business .text button{background:white;border:1px solid #ed1c24;height:40px;border-radius:20px;width:150px;color:#ed1c24;font-weight: bold;position: relative;margin-top:20px;margin:20px auto 0 auto;}
.content .recruit .img{background:url(/resources/company/img/co3.jpg);width:100%;height:198px;text-align: center;line-height: 198px;font-size:18px;font-weight: bold;color:white;}
.content .recruit .text{text-align:center;font-size:14px;text-align: justify;padding:25px;border:1px solid #d3d3d3;border-top:0;position:relative;text-align:center;}
.content .recruit .text button{background:white;border:1px solid #ed1c24;height:40px;border-radius:20px;width:150px;color:#ed1c24;font-weight: bold;position: relative;margin-top:20px;margin:20px auto 0 auto;}

.content .text .text-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 6.25rem;
}

.banner{width:100%;height:399px;background:none;background-position-x: 50%; background-position-y: 50%;background-repeat: no-repeat}
.banner1{width:100%;height:399px;background:url(/resources/company/img/banner1.jpg);background-position-x: 50%; background-position-y: 50%;background-repeat: no-repeat}
.banner2{width:100%;height:399px;background:url(/resources/company/img/banner2.jpg);background-position-x: 50%; background-position-y: 50%;background-repeat: no-repeat}
.banner3{width:100%;height:399px;background:url(/resources/company/img/banner3.jpg);background-position-x: 50%; background-position-y: 50%;background-repeat: no-repeat}


.content2{max-width:1000px;width:1000px;margin:0 auto 0 auto;margin-top:30px;}
.content2 .introduction{text-align: left;}
.content2 .introduction .title{font-size:24px; font-weight: bold;position: relative;}
.content2 .title{font-size:28px;font-weight: bold;margin-top:20px;}
.content2 .title img{float:left;margin-top:14px;}
.content2 .title span{float:left;margin-left:10px;}
.content2 .title:after{content:"";display:block; clear:both;}
.content2 .introduction .detail{margin-top:10px;}
.content2 .introduction .detail:after{clear:both;content:"";display: block;}
.content2 .introduction .detail img{float:right;width:25%;height:25%;}
.content2 .introduction .detail table{width:100%;border-top:1px solid #666;float:left;width:65%;}
.content2 .introduction .detail table tr th{background:#f9f9f9;min-width: 60px;padding:10px;border-bottom:1px solid #d3d3d3;min-width: 90px;}
.content2 .introduction .detail table tr td{background:white;padding:10px;border-bottom:1px solid #d3d3d3;}


.content2{max-width:1000px;width:1000px;margin:0 auto 0 auto;margin-top:30px;}
.content2 .introduction.story{text-align: center; margin-top: 20px;}
.content2 .introduction.story .title{font-size:24px; font-weight: bold;position: relative;}
.content2 .title{font-size:28px;font-weight: bold;margin-top:20px;}
.content2 .title img{float:left;margin-top:14px;}
.content2 .title span{float:left;margin-left:10px;}
.content2 .title:after{content:"";display:block; clear:both;}
.content2 .introduction.story .detail{margin-top:10px;}
.content2 .introduction.story .detail:after{clear:both;content:"";display: block;}
.content2 .introduction.story .detail.pc{display: block;}
.content2 .introduction.story .detail.mo{display: none;}
.content2 .introduction.story .detail img{float:right;width:25%;height:25%;}
.content2 .introduction.story .detail table{width:100%;border-top:1px solid #666;float:left;}
.content2 .introduction.story .detail table tr th{background:#f9f9f9;min-width: 60px;padding:10px;border-bottom:1px solid #d3d3d3;min-width: 90px;}
.content2 .introduction.story .detail table tr td{background:white;padding:10px;border-bottom:1px solid #d3d3d3;}
.content2 .introduction.story .detail table tr th:nth-of-type(odd) {min-width: 39px; border-right:1px solid #d3d3d3}
.content2 .introduction.story .detail table tr td:nth-of-type(odd) {border-right:1px solid #d3d3d3;background-color: #f9f9f9;}
.content2 .introduction.story .detail table tr td:nth-of-type(even) {text-align: left;}
.content2 .introduction.story .detail table tr th:nth-child(4n-1) {border-left: 1px solid #d3d3d3;}
.content2 .introduction.story .detail table tr td:nth-child(4n-1) {border-left: 1px solid #d3d3d3;}

.content2 .business_area{text-align: left;margin-top:50px;}
.content2 .business_area .title{font-size:24px; font-weight: bold;position: relative;}
.content2 .business_area .detail{margin-top:10px;line-height: 1.5em;}
.content2 .business_area .detail .summary{font-size:16px}
.content2 .business_area .detail .detail1{margin-top:30px;}
.content2 .business_area .detail .detail1 .title1 .bull{float:left;margin-top:2px;}
.content2 .business_area .detail .detail1 .title1 .subtitle{float:left;margin-left:10px;font-size:18px;font-weight: bold;}
.content2 .business_area .detail .detail1 .title1:after{clear:both;content:"";display: block}
.content2 .business_area .detail .detail1 .text{background:#f9f9f9;padding:30px; margin-top:20px;color:#444; font-size:16px;line-height: 1.5;}
.content2 .business_area .detail .detail1 .text ul{}
.content2 .business_area .detail .detail1 .text ul li button{cursor:pointer;height:35px;border-radius:20px;border:1px solid #ed1c24;width:200px;background:#ed1c24;font-weight: bold;color:white;}
.content2 .business_area .detail .detail1 .text ul li{width:95%; border-bottom: 1px solid #d3d3d3; padding: 0 0 10px 15px; margin-top:15px; list-style:none; background: url(../../images/company/bul_disc_gray.png) no-repeat left 8px; background-size: 5px;}
.content2 .business_area .detail .detail1 .text ul li:after{clear:both;content:"";display: block;}
.content2 .business_area .detail .detail1 .text ul li:first-child{margin-top:0; }
.content2 .business_area .detail .detail1 .text ul li .li_left{float: left; width: 70%}
.content2 .business_area .detail .detail1 .text ul li .li_right{float: right;}
.content2 .business_area .detail .detail1 .text .mvno_img {margin-top:20px; background: url(/resources/company/img/img_mvno01.png); width:920px; height:424px;}
.content2 .business_area .detail .detail1 .text .sim_img {margin-top:20px; background: url(/resources/company/img/img_sim01.png); width:920px; height:458px;}
@media (max-width: 767px) {
.content2 .business_area .detail .detail1 .text ul li .li_left{width: 95%}
.content2 .business_area .detail .detail1 .text ul li button{width: 270px;}
.content2 .business_area .detail .detail1 .text .mvno_img { background: url(/resources/company/img/img_mvno02.png) 0 0 no-repeat;background-size: cover;height: 100vh;max-height: 556px;min-height: 300px;width: 100%;max-width: 100%;}
.content2 .business_area .detail .detail1 .text .sim_img { background: url(/resources/company/img/img_sim02.png) 0 0 no-repeat; background-size: cover; height: 100vh; max-height: 556px; min-height: 300px;width: 100%;max-width: 100%;}

}



.content2 .business_area .detail .detail2{margin-top:30px;}
.content2 .business_area .detail .detail2 .title2 .bull{float:left;margin-top:6px;}
.content2 .business_area .detail .detail2 .title2 .subtitle{float:left;margin-left:10px;font-size:18px;font-weight: bold;}
.content2 .business_area .detail .detail2 .title2:after{clear:both;content:"";display: block}
.content2 .business_area .detail .detail2 .text{background:#f9f9f9;padding:15px;margin-top:10px; color:#666;}
.content2 .business_area .detail .detail2 .text ul li{width:95%; list-style:none; background: url(../../images/company/bul_disc_gray.png) no-repeat left 8px; background-size: 5px; padding-left: 15px;}
.content2 .business_area .detail .detail2 .text ul li button{height:35px;border-radius:20px;border:1px solid #ed1c24;width:200px;background:#ed1c24;font-weight: bold;color:white;margin-top:10px;}
.content2 .business_area .detail .detail2 .text ul li:after{clear:both;content:"";display: block;}
.content2 .ceo_message{margin-top:0px;}
.content2 .ceo_message:after{clear:both;content:""; display:block}
.content2 .ceo_message .focus{font-size:24px; margin: 20px 0 40px; letter-spacing: -0.03rem;}
.content2 .ceo_message .focus .ceo_top1, .content2 .ceo_message .focus .ceo_top2 {margin:0; padding:0;display:block;}

@media (max-width: 767px) {
.content2 .ceo_message .focus{font-size: 1.375rem; letter-spacing: -1px; font-weight: 500; margin: -10px 0 15px 0;}
.content2 .ceo_message .focus .ceo_top1, .content2 .ceo_message .focus .ceo_top2 {display:inline; line-height:2rem;}

}
.content2 .ceo_message .photo{width:28%;float:left; }
.content2 .ceo_message .photo img {margin-top:60px; width:315px; margin-left:-35px;}
@media (max-width: 767px) {
.content2 .ceo_message .photo img{margin:0 0 0 0; margin-bottom: 20px; width:315px;}
}
.content2 .ceo_message .text{width:72%;float:right;box-sizing: border-box; padding-right:20px; margin-top:40px;}
.content2 .ceo_message .text .text1{font-size: 16px; color:#666; padding:0; margin:0; word-break:keep-all;}
.content2 .ceo_message .text .ceo_sign{float:right; text-align:right; margin-top:20px; font-size: 16px;}
.content2 .vision .graph{text-align:center;}
.content2 .vision .graph img{width:100%;max-width:800px;}
.content2 .vision .graph2{margin-top:0;}
.content2 .vision .graph2:after{content:"";display:block;clear:both;}
.content2 .vision .graph2 .item3{width:25%;float:left;color:#666;text-align: center;box-sizing: border-box;padding:20px;}
.content2 .vision .graph2 .item3 .title{font-size:16px;color:black;}


.content2 .ci{margin-top:50px;text-align: center;}
.content2 .ci .download{margin-top:30px;position: relative;}
.content2 .ci .download .text{cursor:pointer;position: absolute;top:0;left:50%;color:white;font-weight: bold;margin-left: -30px;margin-top:10px;}
.content2 .ci .download .ci_list{margin-top:50px;}
.content2 .ci .download .ci_list:after{clear:both;content:"";display:block}
.content2 .ci .download .ci_list .ci_item{width:25%;float:left;padding:10px;box-sizing: border-box}
.content2 .ci .download .ci_list .ci_item img{width:100%;}
.content2 .ci .ci_script{text-align: left;background:white;padding:30px;margin-top:30px;color:#666;}
.content2 .ci .ci_script:after{content:"";display: block; clear:both;}
.content2 .ci .ci_script .script1{width:50%; box-sizing: border-box;float:left;padding:20px;border-right:1px solid #d3d3d3}
.content2 .ci .ci_script .script1 .title{font-size:18px;font-weight: bold;color:black;}
.content2 .ci .ci_script .script2{width:50%; box-sizing: border-box;float:left;padding:20px}
.content2 .ci .ci_script .script2 .title{font-size:18px;font-weight: bold;color:black;margin:0;padding:0;}

.content2 .ethic .slo1{font-size:24px;margin-top:30px;}
.content2 .ethic .slo1_script{background:#f9f9f9;padding:30px;color:black;margin-top:10px;}
.content2 .ethic .tabbar{margin-top:30px;cursor:pointer;}
.content2 .ethic .tabbar:after{clear:both;content:"";display:block;}
.content2 .ethic .tabbar div{width:50%;float:left;text-align: center;padding:15px;box-sizing: border-box;border:1px solid #d3d3d3}
.content2 .ethic .tabbar .selected{background:#4f4f4f;color:white;border:1px solid #4f4f4f;border-right:0;}
.content2 .ethic .ul1{margin-top:30px;}
.content2 .ethic .ul1 .title{font-size:18px;border-bottom:1px solid #d3d3d3;padding:15px 0 15px 0;}
.content2 .ethic .ul1 .title img{float:left;height:20px;}
.content2 .ethic .ul1 .title span{float:left;margin-left:10px;margin-top:10px;}
.content2 .ethic .ul1 ul{list-style: none;padding:0;margin:0;font-size:16px;margin-top:20px;color:#666;}
.content2 .ethic table{width:100%;box-sizing:border-box;}
.content2 .ethic table tr th{background:#f9f9f9;padding:10px;border-bottom:1px solid #d3d3d3;}
.content2 .ethic table tr td{padding:10px;border-bottom:1px solid #d3d3d3;}
.content2 .ethic button{cursor:pointer;height:35px;border-radius:20px;border:1px solid #ed1c24;width:200px;background:#ed1c24;font-weight: bold;color:white;margin-top:10px;}
.content2 .ethic .tab2{display:none;}
.content2 .location .title1{margin-top:30px;}
.content2 .location .title1:after{clear:both;content:"";display:block;}
.content2 .location .title1 img{float:left;margin-top:6px;}
.content2 .location .title1 span{font-size:18px; font-weight: bold; float:left;margin-left:10px;}
.content2 .location .location_text{font-size:14px;margin-top:20px;}
.content2 .location .location_text2:after{clear:both;content:"";display: block;}
.content2 .location .location_text2 img{float: left;}
.content2 .location .location_text2 span{float: left;margin-top:20px;margin-left:10px;color:#666;}
.content2 .location .location_text2{font-size:14px;margin-top:20px;}
.content2 .recruit{margin-top:30px;position: relative;}
.content2 .recruit .recruit_item{margin-top:30px;position: relative;}

.content2 .recruit1{ text-align: center;}
.content2 .recruit_detail{margin-top:30px;}
.content2 .recruit_detail .recruit2{ position: relative;width:25%;float:left;box-sizing: border-box;padding:20px;}
.content2 .recruit_detail:after{clear: both;content:"";display:block;}
.content2 .recruit_detail .recruit2 .title{font-size:18px;font-weight: bold;float:left;text-align: left;padding:0;margin:0;margin-left:20px;}
.content2 .recruit_detail .recruit2 img{float:left;height:60px;}
.content2 .recruit_detail .recruit2 .script{clear:both;padding:0;margin:0;font-size:14px;padding-left:20px;color:#666;text-align: left;margin-top:50px;padding-top:20px;}

.content2 .recruit .recruit_item:after{clear:both;content:"";display:block;}
.content2 .recruit .recruit_item .img{width:10%;float:left;display:block;}
.content2 .recruit .recruit_item .img img{width:100%;}
.content2 .recruit .recruit_item .text{float:left;width:80%;margin-left:20px;margin-top:-10px;}
.content2 .recruit .recruit_item .text:after{content:"";display:block; clear:both;}
.content2 .recruit .recruit_item .text .title{font-size:18px;float:left;width:100%;}
.content2 .recruit .recruit_item .text .title:after{clear:both;content: "";display: block;}
.content2 .recruit .recruit_item .text .title img{height:20px;float:left;margin-top:5px;}
.content2 .recruit .recruit_item .text .title span{float: left;}
.content2 .recruit .recruit_item .text .script{float: left;color:#666;margin-top:10px;width:100%;}
.content2 .recruit .recruit_item:last-child{margin-top:30px;}
.content2 .recruit .recruit_item .text .script ul{float:none;position: relative;width:100%;}

.footer{font-size:12px;color: #666;text-align: left;display:block;margin-top:1px solid #d3d3d3;}
.footer .logo2{float:right;margin-top:-30px;margin-right:20px;}

#slider2{display:none;}
#slider{display:block}



.btn_stop {position:absolute;right:48%;bottom:20px;padding:0;border:0;margin:0;margin-right:10px;width:24px;height:24px;background:url(../../images/company/stop.png) no-repeat;background-size:24px 24px;cursor:pointer;margin:0}
.btn_start {position:absolute;right:48%;bottom:20px;padding:0;border:0;margin:0;margin-right:10px;width:24px;height:24px;background:url(../../images/company/play.png) no-repeat;background-size:24px 24px;cursor:pointer;margin:0}

.banner_index {width:100%;position:absolute;right:50%;bottom:25px;text-align:right;box-sizing:border-box}
.banner_index .btn_index {padding:0;border:0;margin:0;margin-right:5px;width:10px;height:10px;border:1px solid #bababa;border-radius:5px;background:#bababa;cursor:pointer}
.banner_index .active {width:33px;height:10px;border:1px solid #787878;border-radius:5px;background:#787878}
.banner_index {content:"";display:block;clear:both}

.banner_index2 {width:100%;position:absolute;right:50%;bottom:25px;text-align:right;box-sizing:border-box}
.banner_index2 .btn_index {padding:0;border:0;margin:0;margin-right:5px;width:10px;height:10px;border:1px solid #bababa;border-radius:5px;background:#bababa;cursor:pointer}
.banner_index2 .active {width:33px;height:10px;border:1px solid #787878;border-radius:5px;background:#787878}
.banner_index2 {content:"";display:block;clear:both}









/* 미디어쿼리 시작 */
@media (max-width: 720px){
    #slider2{display:block;}
    #slider{display:none}

    .header{max-width:1000px; width:100%; margin:0 auto 0 auto;padding:10px 0 10px 0;background:white;z-index:999;border-bottom:1px solid #d3d3d3;}
    .logo{display: none;}
    .gnb{display: none;}

    .content2{padding-left:15px; padding-right:15px;box-sizing: border-box;width:100%;}


    .gnb_mobile{display:block;text-align: center;border-bottom:0px solid #d3d3d3;background:white;top:0;left}
    .gnb_mobile .menu{position: absolute; top: 0.625rem; right: 1.25rem;}
    .gnb_mobile img{height:20px;}
    .sub_menu_mobile{z-index:1000;display:none;position: absolute;background:white;width:100%;text-align: center;font-size:12px;font-weight: bold;box-shadow: 0 5px 5px rgba(0,0,0,0.3)}
    .sub_menu_mobile ul{list-style: none;padding:0;margin:0;border-top:1px solid #d3d3d3;margin-top:10px;}
    .sub_menu_mobile ul li{padding:10px;border-bottom:1px solid #d3d3d3;}
    .banner{width:100%;height:auto;background:url(/resources/company/img/banner1.jpg);background-position-x: 50%; background-position-y: 50%;background-repeat: no-repeat;margin-top:0px;background-size:auto 100%}
    .background_wide_top{width:100%;border-bottom:0px solid #ed1c24;background:white;}

/*
    .link_area .link1{width:100%;text-align: center;background:red;position: relative;}

    .link_area .link2{width:100%;text-align: center;}
    .link_area .link3{width:50%;text-align: center;}
*/
    .link_area .item{width:33%;text-align: center;margin-top:20px;margin-left:0;}
    .link_area .item .text{width:100%;}
    .content{max-width:1000px;width:100%;margin:0 auto 0 auto;display:block;}
    .link_area .link1 .img{width:80px;height:80px;background:url(/resources/company/img/icon1.png);background-repeat: no-repeat;background-position: 50% 50%;border:1px solid #d3d3d3; border-radius: 60px;margin:0 auto 0 auto;}
    .link_area .link2 .img{width:80px;height:80px;background:url(/resources/company/img/icon2.png);background-repeat: no-repeat;background-position: 50% 50%;border:1px solid #d3d3d3; border-radius: 60px;margin:0 auto 0 auto;}
    .link_area .link3 .img{width:80px;height:80px;background:url(/resources/company/img/icon3.png);background-repeat: no-repeat;background-position: 50% 50%;border:1px solid #d3d3d3; border-radius: 60px;margin:0 auto 0 auto;}
    .link_area .link4 .img{width:80px;height:80px;background:url(/resources/company/img/icon4.png);background-repeat: no-repeat;background-position: 50% 50%;border:1px solid #d3d3d3; border-radius: 60px;margin:0 auto 0 auto;}
    .link_area .link5 .img{width:80px;height:80px;background:url(/resources/company/img/icon5.png);background-repeat: no-repeat;background-position: 50% 50%;border:1px solid #d3d3d3; border-radius: 60px;margin:0 auto 0 auto;}
    .content .item2{width:100%;box-sizing: border-box;}
    .footer{padding-left:20px;padding-right:20px;box-sizing: border-box;font-size:11px;}
    .footer .logo2{float:none;margin-top:10px}
    .footer .logo2 img{height:20px;}


    .content2 .introduction .detail {width:100%;border-box;}
    .content2 .introduction .detail table{width:100%;box-sizing: border-box;}
    .content2 .introduction img{display: none;}
    .content2 .ceo_message{padding:20px;margin-top:20px;}
    .content2 .ceo_message .text{width:100%;float:left;box-sizing: border-box;padding-right:0px;margin-top:20px;}
    .content2 .ceo_message .photo{width:100%;float:left;display: flex;justify-content: center;}
    .content2 .ceo_message .photo img{width: 100%;max-width: 315px;}

    .content2 .vision .graph2 .item3{width:50%;height:100%;}
    .content2 .vision .graph2 .item3 img{width:110%}

    .content2 .ci{margin-top:30px;text-align: center;}
    .content2 .ci .ci_main{width:100%;}
    .content2 .ci .download{margin-top:10px;position: relative;}
    .content2 .ci .download .text{position: absolute;top:0;left:50%;color:white;font-weight: bold;margin-left: -30px;margin-top:10px;}
    .content2 .ci .download .ci_list{margin-top:50px;}
    .content2 .ci .download .ci_list:after{clear:both;content:"";display:block}
    .content2 .ci .download .ci_list .ci_item{width:50%;float:left;padding:5px;box-sizing: border-box;}
    .content2 .ci .download .ci_list .ci_item img{width:100%;}
    .content2 .ci .ci_script{text-align: left;background:white;padding:30px;margin-top:30px;color:#666;}
    .content2 .ci .ci_script:after{content:"";display: block; clear:both;}
    .content2 .ci .ci_script .script1{width:100%; box-sizing: border-box;float:left;padding:0px;border-right:0px solid #d3d3d3}
    .content2 .ci .ci_script .script1 .title{font-size:18px;font-weight: bold;color:black;}
    .content2 .ci .ci_script .script2{width:100%; box-sizing: border-box;float:left;padding:0px;margin-top:20px;border-top:1px solid #d3d3d3;padding-top:20px;}
    .content2 .ci .ci_script .script2 .title{font-size:18px;font-weight: bold;color:black;margin:0;padding:0;}

    .content2 .ethic .slo1{font-size:24px;margin-top:30px;}
    .content2 .ethic .slo1_script{background:#f9f9f9;padding:30px;color:black;margin-top:10px;}
    .content2 .ethic .tabbar{margin-top:30px;}
    .content2 .ethic .tabbar:after{clear:both;content:"";display:block;}
    .content2 .ethic .tabbar div{width:50%;float:left;text-align: center;padding:15px;box-sizing: border-box;border:1px solid #d3d3d3}
    .content2 .ethic .tabbar .selected{background:#4f4f4f;color:white;border:1px solid #4f4f4f;border-right:0;}
    .content2 .ethic .ul1{margin-top:0px;padding:10px;}
    .content2 .ethic .ul1 .title{font-size:16px;border-bottom:1px solid #d3d3d3;padding:0px 0 15px 0;}
    .content2 .ethic .ul1 .title img{float:left;height:16px;}
    .content2 .ethic .ul1 .title span{float:left;margin-left:0px;margin-top:10px;width:100%;}
    .content2 .ethic .ul1 ul{list-style: none;padding:0;margin:0;font-size:16px;margin-top:20px;color:#666;}
    .content2 .ethic .ul1 ul{font-size:14px;}
    .content2 .location .location_text2{margin:0;}
    .content2 .location .location_text2 img{display:none;}
    .content2 .location .location_text2 span{margin-left:0;}
    .content2 .business_area .detail .detail2 .text ul{padding:0;list-style: none;margin:0;}
    .content2 .business_area .detail .detail1 .text ul{padding:0;list-style: none;margin:0;}
    .content2 .recruit_detail .recruit2{width:100%;padding:0;margin-bottom:20px;}
    .content2 .recruit .recruit_item .img{width:30%;box-sizing: border-box;}
    .content2 .recruit .recruit_item{width:100%;box-sizing: border-box;}
    .content2 .recruit .recruit_item .text{width:100%;box-sizing: border-box;margin-left:0;}
    .content2 .recruit .recruit_item .text .script ul{box-sizing: border-box;}
    .content2 .recruit .recruit_item .img img{display:none;}
    .content2 .recruit .recruit_item .text .script ul{padding:0;margin:0;padding-left:20px;}
    .content2 .recruit .recruit_item .text .title{margin-top:30px;}
    .content2 .recruit1 img{width:80%;}
    .background_wide{padding:20px 0 20px 0;}
    .background_wide_gray{padding:20px 0 20px 0;}
    .content2 .title{margin-top:0;}
    .content2 .introduction{margin-top:20px}

    .content2 .introduction.story .detail.pc{display: none;}
    .content2 .introduction.story .detail.mo{display: block;}

    .footer{margin-top:1px solid #d3d3d3;}

    .banner_index2 {width:100%;position:absolute;right:0%;bottom:5px;text-align:right;box-sizing:border-box;width:100%;;text-align:center;}
    .background_wide_top{width:100%;min-width:320px;}
    .background_wide{width:100%;min-width:320px;}
    .background_wide2{width:100%;min-width:320px;}

	.content2 .business_area .detail .detail1 .text ul li .li_right{float:left;margin-top:10px;margin-bottom:10px;}

}/* 미디어쿼리 끝 */



.swipe {
  overflow: hidden;
  visibility: hidden;
  position: relative;
}
.swipe-wrap {
  overflow: hidden;
  position: relative;
}
.swipe-wrap > div {
  float:left;
  width:100%;
  position: relative;
}


.dim-layer {display:none; position:fixed; _position:absolute; top:0; left:0; width:100%; height:100%; z-index:100;}
.dim-layer .dimBg {position:absolute; top:0; left:0; width:100%; height:100%; background:#000; opacity:.5; filter:alpha(opacity=50);}
.dim-layer .pop-layer {display:none; position: absolute; top: 50%; left: 50%; height:auto; z-index: 10;}
.pop-container:focus {outline:2px dotted black;}


.dim-layer .pop-layer .pop-container .popup_top {padding:0px 30px;background:#eaeaea;vertical-align:middle}
.dim-layer .pop-layer .pop-container .popup_top .popup_title {font-size:22px;float:left;line-height:15px;font-weight:bold;overflow:visible;}
.dim-layer .pop-layer .pop-container .popup_top .popup_title_h4 {font-size:22px;float:left;line-height:15px;font-weight:bold;overflow:inherit}
.dim-layer .pop-layer a.popup_cancel {cursor:pointer;height:22px; position: absolute; top: 25px; right: 20px;}
.dim-layer .pop-layer a.popup_cancel img {height:22px; border:0px;}
.dim-layer .pop-layer .pop-container .popup_top:after {content:"";display:block;clear:both}
.dim-layer .pop-layer .pop-container .popup_content {overflow-y:auto;padding:30px;background:white;line-height:1.5em;}
.dim-layer .pop-layer .pop-container .popup_content .message {font-size:14px;color:#000;padding-bottom:10px;border-bottom:1px solid #000}
.dim-layer .pop-layer .pop-container .popup_content .message2 {font-size:14px;color:#000;padding-bottom:10px}
.dim-layer .pop-layer .pop-container .popup_content .popup_desc {font-size:14px}
.dim-layer .pop-layer .pop-container .popup_content .popup_desc2 {font-size:12px;padding:10px;background:#fff;border:1px solid #d3d3d3}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning {padding:10px 0 30px 0;font-size:12px;color:#666}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning ul {margin: 0; padding: 0;}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning ul li{margin-left: 15px;line-height:18px;margin-bottom:10px;}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning .notice_sub2 {box-sizing:border-box;font-size:14px;color:#000;padding:30px 0 0 20px;background-image:url(../../images/company/icon_blog_order_active.png);background-repeat:no-repeat;background-position:4px 37px}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning .jejuair_agree {border:1px solid #d3d3d3;border-top:0;margin-bottom:10px}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning .jejuair_agree .agree_title {box-sizing:border-box;padding:15px 10px;background:#f9f9f9;border-bottom:1px solid #ededed;font-size:16px;color:#000}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning .jejuair_agree .agree_content {box-sizing:border-box;height:90px;overflow:auto;padding:20px 15px 5px 15px}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning label {font-size:14px;color:#000}
.dim-layer .pop-layer .pop-container .popup_content .popup_warning .jeju_memberid table {margin-bottom:10px}
.dim-layer .pop-layer .pop-container .popup_content .popup_button {text-align:center}
.dim-layer .pop-layer .pop-container .popup_content .popup_notice {background:#f0f0f0;margin-top:40px;width:100%;padding:10px}
.dim-layer .pop-layer .pop-container .popup_content .btn_group{clear:both; text-align:center; margin-top:10px;}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btnwid {padding:5px 10px;line-height:1.5;border:1px solid #000;color:white;background:#4d4d4f;font-weight:bold;width:32%;float:left;margin-left:2%}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btnwid:first-child {margin-left:0}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btnwid:hover {background:white;color:#000}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btnwid:focus {background:white;color:#000}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btn_center_big_red {min-width:248px;padding:10px 5px;font-size:16px;line-height:22px;border:1px solid #8c1217;color:white;background:#ed1c24;font-weight:bold;height:44px}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btn_center_big_red:hover {opacity:0.7}
.dim-layer .pop-layer .pop-container .popup_content .btn_group .btn_center_big_red:focus {opacity:0.7}
.dim-layer .pop-layer .pop-container .popup_content .btn_group span{font-size: 12px; font-weight: normal;}
.dim-layer .pop-layer .pop-container .popup_content .btn_group:after {content:"";display:block;clear:both}
/*.dim-layer .pop-layer .pop-container .popup_content .btn_join {border-top: 1px solid #d3d3d3;}*/
.dim-layer .pop-layer .pop-container .popup_content .btn_join {padding-top:10px}
/*.dim-layer .pop-layer .pop-container .btn_join:hover{border-top: 1px solid #333;}*/
.dim-layer .pop-layer .pop-container .btn_join .pop_join {width: 100%; height: 46px; border: none; background-color: #f9f9f9; font-weight: bold;}
.dim-layer .pop-layer .pop-container .btn_join .pop_join:hover {background-color: #fff; }

.dim-layer .pop-layer .pop-container .appform_cancel .popup_top {box-sizing:border-box}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_top .popup_title {font-size:24px;letter-spacing:-2px;font-weight:normal}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_top .popup_title span {color:#ed1c24}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content {box-sizing:border-box;padding:0 30px}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table {border-collapse:collapse;width:100%}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr th {vertical-align:top;text-align:center;padding-top:30px;border-top:1px solid #d3d3d3}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr:first-child th {border-top:0}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td {padding:30px 0 25px 10px;border-top:1px solid #d3d3d3}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr:first-child td {border-top:0}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td .step_title {font-size:22px;letter-spacing:-2px;padding-bottom:15px}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td .step_desc {font-size:18px;padding-bottom:10px}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td .step_check {padding-top:10px}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td .check_item {padding-bottom:10px}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td .check_item img {height:14px;margin-right:10px;margin-bottom:-2px}

.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr td.haed {vertical-align:top;text-align:center;padding-top:30px;border-top:1px solid #d3d3d3}
.dim-layer .pop-layer .pop-container .appform_cancel .popup_content table tr:first-child td.haed {border-top:0}



.dim-layer .pop-layer {display:block;}

.dim-popup {position:relative;top:0;left:0;width:100%;height:100%}
.dim-popup .pop-container {}
.dim-popup .pop-container .popup_print_title{border-bottom: 2px solid black; height: 50px; font-size: 24px; font-weight: bold; text-align: left; vertical-align: middle; margin: 20px 0; }
.dim-popup .pop-container .popup_top {padding:15px;background:#eaeaea;vertical-align:middle}
.dim-popup .pop-container .popup_top .popup_title {font-size:24px;float:left;font-weight:bold}
.dim-popup a.popup_cancel {position: absolute; top:20px; right: 20px;cursor:pointer;height:22px}
.dim-popup a.popup_cancel img {height:22px}
.dim-popup .pop-container .popup_top:after {content:"";display:block;clear:both}
.dim-popup .pop-container .popup_content {padding:30px;background:white}
.dim-popup .pop-container .popup_content .message {font-size:14px;color:#000;padding-bottom:10px;border-bottom:1px solid #000}
.dim-popup .pop-container .popup_content .message2 {font-size:14px;color:#000;padding-bottom:10px}
.dim-popup .pop-container .popup_content .popup_desc {font-size:14px}
.dim-popup .pop-container .popup_content .popup_desc2 {font-size:12px;padding:10px;background:#fff;border:1px solid #d3d3d3}
.dim-popup .pop-container .popup_content .popup_warning {padding:20px 0 30px 0;font-size:12px;color:#666}
.dim-popup .pop-container .popup_content .popup_button {text-align:center}
.dim-popup .pop-container .popup_content .popup_notice {background:#f0f0f0;margin-top:40px;width:100%;padding:10px}
.dim-popup .pop-container .popup_content .cs_storeDetail table tr td {padding-right:10px}

.dim-layer .pop-layer_red {display:none;position:absolute;top:50%;left:50%;height:auto;z-index:10}
.dim-layer .pop-layer_red p {margin:0;padding:0}
.dim-layer .pop-layer_red .red_top {padding:24px 30px;background:#ed1c24;vertical-align:middle}
.dim-layer .pop-layer_red .red_top .red_title {font-size:24px;float:left;line-height:15px;font-weight:bold;color:#fff;overflow:visible;}
.dim-layer .pop-layer_red a.popup_cancel {position: absolute; top:20px; right: 20px; cursor:pointer;height:22px}
.dim-layer .pop-layer_red a.popup_cancel img {height:22px}
.dim-layer .pop-layer_red .red_top:after {content:"";display:block;clear:both}
.dim-layer .pop-layer_red .popup_content {padding:30px 20px 30px 30px;background:#fff;overflow:auto;line-height:2em;}

.dim-layer .pop-layer_red .popup_content .title {font-size:32px;color:#000;font-weight:bold;margin-top:-10px;line-height:1.3em;}
.dim-layer .pop-layer_red .popup_content .title p {font-size:16px;color:#333;font-weight:normal}
.dim-layer .pop-layer_red .popup_content .summary {border-top:1px solid #000;margin-top:25px;width: 900px; height: 146px; box-sizing:border-box;display:table;*display:block;}
.dim-layer .pop-layer_red .popup_content .summary:after {content:"";display:block;clear:both}
.dim-layer .pop-layer_red .popup_content .summary .price {box-sizing:border-box;display:table-cell;vertical-align:middle;*float:left;width:295px;border-bottom:1px solid #d3d3d3; padding: 20px 0;}
.dim-layer .pop-layer_red .popup_content .summary .price:after {content:"";display:block;clear:both}
.dim-layer .pop-layer_red .popup_content .summary .price .price_box {width:227px;box-sizing:border-box;display:table;*display:block; margin: 35px auto; }
.dim-layer .pop-layer_red .popup_content .summary .price .price_box2 {width:227px;box-sizing:border-box;display:table;*display:block; margin: 0 auto; }
.dim-layer .pop-layer_red .popup_content .summary .price .price_tit {box-sizing:border-box;display:table-cell;vertical-align:top;*float:left;font-size:14px;color:#666;font-weight:bold;width:82px; text-align: left;}
.dim-layer .pop-layer_red .popup_content .summary .price .price_txt {box-sizing:border-box;display:table-cell;vertical-align:middle;*float:left;font-size:16px;color:#000;font-weight:bold;width:120px;margin:-7px 0 15px 18px; text-align: right;}
.dim-layer .pop-layer_red .popup_content .summary .price .price_txt span {font-size:28px;font-weight:bold}
.dim-layer .pop-layer_red .popup_content .summary .price .price_txt p {font-size:14px;font-weight:normal;color:#666}
.dim-layer .pop-layer_red .popup_content .summary .price .price_txt .font_red {color:#ed1c24}
