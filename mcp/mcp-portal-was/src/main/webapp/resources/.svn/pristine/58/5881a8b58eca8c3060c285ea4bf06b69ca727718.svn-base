.today-stop-button {
  padding: 0;
  margin: 0;
  text-decoration: none;
  color: inherit;
  font-size: inherit;
  letter-spacing: inherit;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
  -webkit-tap-highlight-color: transparent;
  font-size: 1rem;
  font-weight: 500;
  color: #4c4c4c;
}

@media (max-width: 767px) {

	#noticeInfo.pop-layer {
	  width: calc(100% - 1.75rem);
	}
	#noticeInfo.pop-layer .pop-container {
	  width: 100%;
	}
	#noticeInfo.pop-layer .pop-container .popup_top {
	  width: 100% !important;
	  padding: 0 3rem 0 1.25rem;
	  border-radius: 1rem 1rem 0 0;
	}
	#noticeInfo.pop-layer .pop-container .popup_top .popup_title_h4 {
	  font-size: 1.125rem;
	  line-height: normal;
	}

	#noticeInfo.pop-layer .pop-container .popup_content {
	    max-width: 100%;
	    padding: 1.25rem 1.25rem;
	}

	#noticeInfo.pop-layer .pop-container .popup_content .content2 {
	    padding-left: 0;
	    padding-right: 0;
	}

}