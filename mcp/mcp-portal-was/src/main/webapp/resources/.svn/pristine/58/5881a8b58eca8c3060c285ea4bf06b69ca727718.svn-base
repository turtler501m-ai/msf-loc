.dim-layer .pop-layer_red .popup_content .summary .icon {box-sizing:border-box;display:table-cell;vertical-align:middle;*float:left;background-color:#f9f9f9;width:603px; border-left: 1px solid #d3d3d3;border-bottom:1px solid #d3d3d3;position: relative;}
.dim-layer .pop-layer_red .popup_content .summary .icon:after {content:"";display:block;clear:both}
.dim-layer .pop-layer_red .popup_content .summary .icon .tin {font-size:12px;font-weight:normal;color:#666; position: absolute; right: 30px; top: 10px;}
.dim-layer .pop-layer_red .popup_content .summary .icon .tell{background: url(../../images/company/icon_fee_tell.png) no-repeat;width: 126px; height: 72px; display: block; float: left;margin-left: 30px; margin-top: 15px; display: table;}
.dim-layer .pop-layer_red .popup_content .summary .icon .sms{background: url(../../images/company/icon_fee_sms.png) no-repeat;width: 129px; height: 72px; display: block; float: left; margin-left: 10px;margin-top: 15px; display: table;}
.dim-layer .pop-layer_red .popup_content .summary .icon .data{background: url(../../images/company/icon_fee_data.png) no-repeat;width: 133px; height: 72px; display: block;float: left; margin-left: 10px;margin-top: 15px; display: table;}
.dim-layer .pop-layer_red .popup_content .summary .icon .data_3g{background: url(../../images/company/icon_fee_data_3g.png) no-repeat;width: 133px; height: 72px; display: block;float: left; margin-left: 10px;margin-top: 15px; display: table;}
.dim-layer .pop-layer_red .popup_content .summary .icon .wifi{background: url(../../images/company/icon_fee_wifi.png) no-repeat;width: 130px; height: 72px; display: block;float: left; margin-left: 10px;margin-top: 15px; display: table;}
.dim-layer .pop-layer_red .popup_content .summary .icon .text{font-weight: bold; color: #ed1c24; display: table-cell; vertical-align: middle; padding-left: 42px; text-align: center; line-height: 1.5;}

.dim-layer .pop-layer_red .popup_content .notice {}
.dim-layer .pop-layer_red .popup_content .notice ul {margin:0;padding:15px 0;list-style:disc; list-style-position: inside; color:#666}
.dim-layer .pop-layer_red .popup_content .notice .img ul {margin:0;padding:15px 0;list-style:none; }
.dim-layer .pop-layer_red .popup_content .notice .img ul li{float:left; margin-left: 30px;margin-top:30px;}
