function getJehuInfo() {
    if ($("#jehuProdType").val() != null && $("#jehuProdType").val() != "" ){
        $("._clauseJehuFlag").show();
    } else {
        $("._clauseJehuFlag").hide();
    }
    if ($("#jehuPartnerType").val() != null && $("#jehuPartnerType").val() != "" ){
        $("._clausePartnerOfferFlag").show();
    } else {
