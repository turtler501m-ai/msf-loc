            validator.config['minorAgentRrn01'] = 'isNonEmpty';
            validator.config['minorAgentRrn02'] = 'isNonEmpty';
            validator.config['minorAgentTelFn'] = 'isNonEmpty';
            validator.config['minorAgentTelMn'] = 'isNonEmpty';
            validator.config['minorAgentTelRn'] = 'isNonEmpty';
            validator.config['minorAgentTelFn'] = 'isNumFix3';
            validator.config['minorAgentTelMn'] = 'isNumBetterFixN3';
            validator.config['minorAgentTelRn'] = 'isNumFix4';
            validator.config['minorAgentTelFn&minorAgentTelMn&minorAgentTelRn'] = 'isPhoneNumberCheck';
            validator.config['minorAgentAgrmYn'] = 'isNonEmpty';
            
            pageObj.applDataForm.cstmrNativeRrn = $.trim($("#cstmrNativeRrn01").val()) + $.trim($("#cstmrNativeRrn02").val());
            pageObj.applDataForm.minorAgentName = $.trim($("#minorAgentName").val());
            pageObj.applDataForm.minorAgentRelation = $("#minorAgentRelation").val();
            pageObj.applDataForm.minorAgentRrn = $.trim($("#minorAgentRrn01").val()) + $.trim($("#minorAgentRrn02").val()) ;
            pageObj.applDataForm.minorAgentTel = $.trim($("#minorAgentTelFn").val()) + $.trim($("#minorAgentTelMn").val()) + $.trim($("#minorAgentTelRn").val());
            pageObj.applDataForm.minorAgentAgrmYn = $("#minorAgentAgrmYn").is(":checked") ? "Y":"N";
        } else if (asCstmrType == CSTMR_TYPE.FN) {
            validator.config['cstmrForeignerRrn01'] = 'isNonEmpty';
            validator.config['cstmrForeignerRrn02'] = 'isNonEmpty';
            
            pageObj.applDataForm.cstmrNativeRrn = $.trim($("#cstmrForeignerRrn01").val()) + $.trim($("#cstmrForeignerRrn02").val());            
        }

        validator.config['notice3'] = 'isNonEmpty';
        validator.config['clausePriCollectFlag'] = 'isNonEmpty';
        validator.config['clausePriOfferFlag'] = 'isNonEmpty';
        validator.config['clauseEssCollectFlag'] = 'isNonEmpty';
        validator.config['clauseFathFlag01'] = 'isNonEmpty';
        validator.config['clauseFathFlag02'] = 'isNonEmpty';
        //validator.config['clauseConfidenceFlag'] = 'isNonEmpty';
        validator.config['notice'] = 'isNonEmpty';
        if ($("#jehuProdType").val() != null && $("#jehuProdType").val() != "") {
            validator.config['clauseJehuFlag'] = 'isNonEmpty';
            pageObj.applDataForm.clauseJehuFlag = $("#clauseJehuFlag").is(":checked") ? "Y":"N";
            pageObj.applDataForm.jehuProdType = $.trim($("#jehuProdType").val());
        }
        pageObj.applDataForm.clausePriCollectFlag = $("#clausePriCollectFlag").is(":checked") ? "Y":"N";
        pageObj.applDataForm.clausePriOfferFlag = $("#clausePriOfferFlag").is(":checked") ? "Y":"N";
        pageObj.applDataForm.clauseEssCollectFlag = $("#clauseEssCollectFlag").is(":checked") ? "Y":"N";
        pageObj.applDataForm.clauseFathFlag = $("#clauseFathFlag01").is(":checked") && $("#clauseFathFlag02").is(":checked") ? "Y":"N";
        //pageObj.applDataForm.clauseConfidenceFlag = $("#clauseConfidenceFlag").is(":checked") ? "Y":"N";
        pageObj.applDataForm.clausePriAdFlag = $("#clausePriAdFlag").is(":checked") ? "Y":"N";
        //pageObj.applDataForm.clauseFinanceFlag = $("#clauseFinanceFlag").is(":checked") ? "Y":"N";
        pageObj.applDataForm.personalInfoCollectAgree = $("#personalInfoCollectAgree").is(":checked") ? "Y":"N";
        pageObj.applDataForm.othersTrnsAgree = $("#formOthersTrnsAgree").is(":checked") ? "Y":"N";
        pageObj.applDataForm.othersTrnsKtAgree = $("#formOthersTrnsKtAgree").is(":checked") ? "Y":"N";
        pageObj.applDataForm.othersAdReceiveAgree = $("#othersAdReceiveAgree").is(":checked") ? "Y":"N";

        pageObj.applDataForm.reqInfoChgYn = $('input:radio[name=reqInfoChgYn]:checked').val();
        pageObj.applDataForm.soc = $("#selContractNum option:selected").attr("data-soc");
        pageObj.applDataForm.socNm = $("#selContractNum option:selected").attr("data-soc_nm");

        //가입정보 변경 체크시에만
        if (pageObj.applDataForm.reqInfoChgYn == "Y") {
            validator.config['cstmrPost'] = 'isNonEmpty';
            pageObj.applDataForm.cstmrPost = $.trim($("#cstmrPost").val());
            pageObj.applDataForm.cstmrAddr = $("#cstmrAddr").val();
            pageObj.applDataForm.cstmrAddrDtl = $("#cstmrAddrDtl").val();
            pageObj.applDataForm.cstmrBillSendCode = $('input:radio[name=cstmrBillSendCode]:checked').val();

            //명세서 수신유형이 이메일명세서 일때만 필수
            if (pageObj.applDataForm.cstmrBillSendCode == "CB") {
                validator.config['cstmrMail'] = 'isNonMail';
            }
            pageObj.applDataForm.cstmrMail = $.trim($("#cstmrMail").val());

            pageObj.applDataForm.reqPayType = $('input:radio[name=reqPayType]:checked').val();
            if (pageObj.applDataForm.reqPayType == "D") {
                //자동이체
                validator.config['reqBank'] = 'isNonEmpty';
                validator.config['reqAccountNumber'] = 'accountChk';
                validator.config['isCheckAccount'] = 'isNonEmpty';
                pageObj.applDataForm.reqBank = $("#reqBank").val();
                pageObj.applDataForm.reqAccountNumber = $.trim($("#reqAccountNumber").val());
            } else if (pageObj.applDataForm.reqPayType == "C") {
                validator.config['reqCardCompany'] = 'isNonEmpty';
                validator.config['reqCardNo'] = 'isCheckCardNumberAll';
                validator.config['reqCardMm'] = 'isNonEmpty';
                validator.config['reqCardYy'] = 'isNonEmpty';
                validator.config['isCheckCard'] = 'isNonEmpty';

                pageObj.applDataForm.reqCardCompany = $.trim($("#reqCardCompany").val());
                pageObj.applDataForm.reqCardNo = $.trim($("#reqCardNo").val()) ;
                pageObj.applDataForm.reqCardYy = $.trim($("#reqCardYy").val());
                pageObj.applDataForm.reqCardMm = $.trim($("#reqCardMm").val());
            }
        }

        //신분증 타입
        validator.config['selfCertType1'] = 'isNonEmpty';
        pageObj.applDataForm.selfCertType = $("input:radio[name=selfCertType]:checked").val();

        //안면인증 
        if($("#fathTrgYn").val() == "Y") {
            validator.config['isFathTxnRetv'] = 'isNonEmpty';
        }
        pageObj.applDataForm.fathTrgYn = $("#fathTrgYn").val();

        validator.config['selfIssuExprDt'] = 'isIssuDate';
        pageObj.applDataForm.selfIssuExprDt = $("#selfIssuExprDt").val().replace(/-/gi,"");
        if (pageObj.applDataForm.selfCertType=="02") {
            validator.config['driverSelfIssuNum1'] = 'isNonEmpty';
            validator.config['driverSelfIssuNum2'] = 'isNumFix10';
            pageObj.applDataForm.selfIssuNum = $("#driverSelfIssuNum1").val() + $.trim($("#driverSelfIssuNum2").val());
        } else if (pageObj.applDataForm.selfCertType=="04") {
            validator.config['selfIssuNum'] = 'isNonEmpty';
            pageObj.applDataForm.selfIssuNum = $("#selfIssuNum").val();
        } else if (pageObj.applDataForm.selfCertType=="06") {
            validator.config['cstmrForeignerNation'] = 'isNonEmpty';
            pageObj.applDataForm.cstmrForeignerNation = $("#cstmrForeignerNation").val();
        }

        validator.config['cstmrReceiveTelFn'] = 'isNonEmpty';
        validator.config['cstmrReceiveTelMn'] = 'isNonEmpty';
        validator.config['cstmrReceiveTelRn'] = 'isNonEmpty';
        validator.config['cstmrReceiveTelFn'] = 'isNumFix3';
        validator.config['cstmrReceiveTelMn'] = 'isNumBetterFixN3';
        validator.config['cstmrReceiveTelRn'] = 'isNumFix4';
        validator.config['cstmrReceiveTelFn&cstmrReceiveTelMn&cstmrReceiveTelRn'] = 'isPhoneNumberCheck';
        pageObj.applDataForm.cstmrReceiveTelFn = $.trim($("#cstmrReceiveTelFn").val());
        pageObj.applDataForm.cstmrReceiveTelMn = $.trim($("#cstmrReceiveTelMn").val());
        pageObj.applDataForm.cstmrReceiveTelRn = $.trim($("#cstmrReceiveTelRn").val());

        validator.config['selfInqryAgrmYnFlag'] = 'isNonEmpty';
        pageObj.applDataForm.selfInqryAgrmYn = $("#selfInqryAgrmYnFlag").is(":checked") ? "Y" : "N";

        if (validator.validate()) {
            //연락처체크
            //명의변경 회선과 법정대리인 연락처가 같은지 체크
            pageObj.applDataForm.chkTelType = "NEE";
            var chkData = ajaxCommon.getSerializedData(pageObj.applDataForm);
            ajaxCommon.getItem({
                id:'nameChgChkTelNo'
                ,cache:false
                ,url:'/mypage/nameChgChkTelNo.do'
                ,data: chkData
                ,async:true
                ,dataType:"json"
            }, function(jsonObj) {
                if (AJAX_RESULT_CODE.SUCCESS != jsonObj.RESULT_CODE) {
                    MCP.alert(jsonObj.RESULT_MSG);
                    return false;
                } else {
                    KTM.Confirm('신청 후 수정이 불가하오니 작성 내용을 다시 확인 부탁드립니다. 양수인 명의변경을 신청하시겠습니까?' ,function () {
                        $('#divAsReq').hide(); //양수인 신청 div 숨기기

                        $('#tdAsReqStat').html("");
                        $('#tdAsReqStat').html("인증 및 신청완료");
                        assigneeReqYn = "Y";

                        // 양수인, 양도인 신청완료시 명의변경버튼 생성
                        if (grantorReqYn == "Y" && assigneeReqYn == "Y") {
                            $('#btnNameChg').removeClass("is-disabled");
                            $('#btnNameChg').prop("disabled",false);
                        }
                        this.close();
                        MCP.alert("양수인 명의변경 신청이 완료되었습니다.");
                    });
                }
            })

        } else {
            var errId = validator.getErrorId();
            //console.log("errId==>" + errId);
            MCP.alert(validator.getErrorMsg() ,function (){
                $selectObj = $("#"+errId);
                viewErrorMgs($selectObj, validator.getErrorMsg());
            });
            return false;
        }
    })

    //명의변경 신청
    $('#btnNameChg').click(function(){
        KTM.Confirm('명의변경을 신청하시겠습니까?' ,function () {
            this.close();
            if ($("#isAuth").val() != "1") {
                MCP.alert("양도인 인증이 완료되지 않았습니다. ");
                return false;
            }
            if ($("#isAuth2").val() != "1") {
                MCP.alert("양수인 인증이 완료되지 않았습니다. ");
                return false;
            }
            if (grantorReqYn != "Y") {
                MCP.alert("양도인 인증 및 신청을 완료해주세요. ");
                return false;
            }
            if (assigneeReqYn != "Y") {
                MCP.alert("양수인 인증 및 신청을 완료해주세요. ");
                return false;
            }

            var varData = ajaxCommon.getSerializedData(pageObj.applDataForm);

            ajaxCommon.getItem({
                id:'myNameChgRequest'
                ,cache:false
                ,url:'/mypage/myNameChgRequest.do'
                ,data: varData
                ,async:false
                ,dataType:"json"
                ,errorCall : function () {
                    //nothing
                }
            }
            ,function(jsonObj){

                var resultCd= jsonObj.RESULT_CODE;
                if (AJAX_RESULT_CODE.SUCCESS == resultCd) {
                    MCP.alert("명의변경 신청이 완료되었습니다. (영업일 기준 D+1일 이내에 명의변경 신청내용 확인 안내전화를 드립니다)",function (){
                        location.href="/main.do";
                    });
                } else if(resultCd == "AUTH01" || resultCd == "AUTH02"){ // AUTH 오류
                    MCP.alert(jsonObj.RESULT_MSG);

                } else if(resultCd == "STEP01" || resultCd == "STEP02" || resultCd == "STEP03"){ // STEP 오류
                    MCP.alert(jsonObj.RESULT_MSG);

                } else {
                    MCP.alert("명의변경 신청에 실패하였습니다. 자세한 사항은 고객센터(114/무료)로 문의 부탁드립니다.");
                }
            })
        });
    })
    $('.c-accordion.c-accordion--nested > .c-accordion__box > .c-accordion__item > .c-accordion__head .c-accordion__button, .c-accordion.c-accordion--nested__sub > .c-accordion__box > .c-accordion__item > .c-accordion__head .c-accordion__button').click(function() {
        handleAccordionClick(this);
    });
    
    // 페이지 오픈시 기본값
    $('#cstmrType1').click();

    updateFathSkipBtnVisibility();
})



var fnNiceCert = function(prarObj) {
    var cstmrNativeRrn ;
    var cstmrName ;
    var cstmrMinorRrn ;
    var cstmrMinorName ;

    var strMsg= "고객 정보와 본인인증한 정보가 틀립니다.";
    pageObj.niceResLogObj = prarObj;

    //본인인증
    if (pageObj.niceType == NICE_TYPE.CUST_AUTH) {

        var cstomerType = $("#selContractNum option:selected").attr("data-customer_type");
        if (cstomerType != "I") {
            MCP.alert("지원하지 않는 고객유형 입니다.");
            return ;
        }

        // 양도인일 경우 authForGr은 true, 양수인일 경우 authForGr은 false
        var authForGr= ($('#divGrReq').css("display")=="block") ? true: false;

        var grCstmrType = $("#selContractNum option:selected").attr("data-cstmr_type");
        var asCstmrType = $("input:radio[name=cstmrType]:checked").val();
        if (authForGr) { // 양도인 입력 정보
            pageObj.niceResLogObj = prarObj;
            if (grCstmrType == CSTMR_TYPE.NA) {
                //내국인
                cstmrNativeRrn = $.trim($("#grCstmrNativeRrn01").val());
                cstmrName = $.trim($("#grCstmrName").val());
                strMsg = '<p class="u-mt--12"><strong class="u-fw--bold">본인인증 정보가 일치하지 않습니다.</strong></p><p class="u-mt--12">입력하신 정보를 확인 후 다시 시도해 주시기 바랍니다.</p>';
            } else if (grCstmrType == CSTMR_TYPE.NM) {
                //청소년
                cstmrNativeRrn = $.trim($("#grCstmrNativeRrn01").val());
                cstmrName = $.trim($("#grCstmrName").val());
                cstmrMinorRrn = $.trim($("#grMinorAgentRrn01").val());
                cstmrMinorName = $.trim($("#grMinorAgentName").val());
                strMsg = '<p class="u-mt--12"><strong class="u-fw--bold">법정대리인 본인인증 정보가<br/>일치하지 않습니다.</strong></p><p class="u-mt--12">입력하신 정보를 확인 후 다시 시도해 주시기 바랍니다.</p>';
            } else if (grCstmrType == CSTMR_TYPE.FN) {
                //외국인
                cstmrNativeRrn = $.trim($("#grCstmrForeignerRrn01").val());
                cstmrName = $.trim($("#grCstmrName").val());
                strMsg = '<p class="u-mt--12"><strong class="u-fw--bold">본인인증 정보가 일치하지 않습니다.</strong></p><p class="u-mt--12">입력하신 정보를 확인 후 다시 시도해 주시기 바랍니다.</p>';
            } else {
                MCP.alert("지원하지 않는 고객유형 입니다.");
                return ;
            }
            
        } else { // 양수인 입력 정보
            pageObj.niceResLogObj2 = prarObj;
            if (asCstmrType == CSTMR_TYPE.NA) {
                //내국인
                cstmrNativeRrn = $.trim($("#cstmrNativeRrn01").val());
                cstmrName = $.trim($("#cstmrName").val());
                strMsg = '<p class="u-mt--12"><strong class="u-fw--bold">본인인증 정보가 일치하지 않습니다.</strong></p><p class="u-mt--12">입력하신 정보를 확인 후 다시 시도해 주시기 바랍니다.</p>';
            } else if (asCstmrType == CSTMR_TYPE.NM) {
                //청소년
                cstmrNativeRrn = $.trim($("#minorAgentRrn01").val());
                cstmrName = $.trim($("#minorAgentName").val());
                strMsg = '<p class="u-mt--12"><strong class="u-fw--bold">법정대리인 본인인증 정보가<br/>일치하지 않습니다.</strong></p><p class="u-mt--12">입력하신 정보를 확인 후 다시 시도해 주시기 바랍니다.</p>';
            } else if (asCstmrType == CSTMR_TYPE.FN) {
                //외국인
                cstmrNativeRrn = $.trim($("#cstmrForeignerRrn01").val());
                cstmrName = $.trim($("#cstmrName").val());
                strMsg = '<p class="u-mt--12"><strong class="u-fw--bold">본인인증 정보가 일치하지 않습니다.</strong></p><p class="u-mt--12">입력하신 정보를 확인 후 다시 시도해 주시기 바랍니다.</p>';
            } else {
                MCP.alert("지원하지 않는 고객유형 입니다.");
                return ;
            }
        }

        var authInfoJson= {cstmrName: cstmrName, cstmrNativeRrn: cstmrNativeRrn, authType: prarObj.authType};

        // 양수인인 경우 isSecond 추가 (niceLog insert 후 양도인과 다른 변수에 값을 담기 위함) > niceAuth.js 참고
        var isAuthDone= false;
        if (authForGr) { // 양도인
            authInfoJson.contractNum= $("#selContractNum option:selected").val();
            authInfoJson.ncType= "0"
            authInfoJson.cstmrType= grCstmrType
            authInfoJson.cstmrMinorName= cstmrMinorName
            authInfoJson.cstmrMinorRrn= cstmrMinorRrn
            isAuthDone= mypageAuthCallback(authInfoJson);
        } else { // 양수인
            authInfoJson.isSecond= "Y";
            authInfoJson.ncType= asCstmrType == CSTMR_TYPE.NM ? "3" : "1"; // 1: 양수인, 3: 양수인 법정대리인
            isAuthDone= authCallback(authInfoJson);
        }

        if (isAuthDone){ // 본인인증 성공 시 처리
            if (authForGr) { // 양도인
                pageObj.authObj= prarObj ;
                if (grCstmrType == CSTMR_TYPE.NA) {
                    //내국인
                    $('#grCstmrType1').prop('disabled', false);
                    $('#grCstmrType2').prop('disabled', true);
                    $('#grCstmrType3').prop('disabled', true);
                    
                    $("#grCstmrName").prop('readonly', 'readonly');
                    $("#grCstmrNativeRrn01").prop('readonly', 'readonly');
                    $("#grCstmrNativeRrn02").prop('readonly', 'readonly');
                } else if (grCstmrType == CSTMR_TYPE.NM) {
                    //청소년
                    $('#grCstmrType1').prop('disabled', true);
                    $('#grCstmrType2').prop('disabled', false);
                    $('#grCstmrType3').prop('disabled', true);
                    
                    $("#grCstmrName").prop('readonly', 'readonly');
                    $("#grCstmrNativeRrn01").prop('readonly', 'readonly');
                    $("#grCstmrNativeRrn02").prop('readonly', 'readonly');
                    $("#grMinorAgentName").prop('readonly', 'readonly');
                    $("#grMinorAgentRrn01").prop('readonly', 'readonly');
                    $("#grMinorAgentRrn02").prop('readonly', 'readonly');
                } else if (grCstmrType == CSTMR_TYPE.FN) {
                    //외국인
                    $('#grCstmrType1').prop('disabled', true);
                    $('#grCstmrType2').prop('disabled', true);
                    $('#grCstmrType3').prop('disabled', false);
                    
                    $("#grCstmrName").prop('readonly', 'readonly');
                    $("#grCstmrForeignerRrn01").prop('readonly', 'readonly');
                    $("#grCstmrForeignerRrn02").prop('readonly', 'readonly');
                } else {
                    MCP.alert("지원하지 않는 고객유형 입니다.");
                    return ;
                }
            } else { // 양수인
                pageObj.authObj2= prarObj ;
                $("#cstmrName").prop('readonly', 'readonly');
                $("#cstmrNativeRrn01").prop('readonly', 'readonly');
                $("#cstmrNativeRrn02").prop('readonly', 'readonly');

                if (asCstmrType == CSTMR_TYPE.NA) {
                    //내국인                    
                    $('#cstmrType1').prop('disabled', false);
                    $('#cstmrType2').prop('disabled', true);
                    $('#cstmrType3').prop('disabled', true);
                } else if (asCstmrType == CSTMR_TYPE.NM) {
                    //청소년
                    $('#cstmrType1').prop('disabled', true);
                    $('#cstmrType2').prop('disabled', false);
                    $('#cstmrType3').prop('disabled', true);
                    
                    $("#minorAgentName").prop('readonly', 'readonly');
                    $("#minorAgentRrn01").prop('readonly', 'readonly');
                    $("#minorAgentRrn02").prop('readonly', 'readonly');
                } else if (asCstmrType == CSTMR_TYPE.FN) {
                    //외국인
                    $('#cstmrType1').prop('disabled', true);
                    $('#cstmrType2').prop('disabled', true);
                    $('#cstmrType3').prop('disabled', false);
                    
                    $("#cstmrForeignerRrn01").prop('readonly', 'readonly');
                    $("#cstmrForeignerRrn02").prop('readonly', 'readonly');
                } else {
                    MCP.alert("지원하지 않는 고객유형 입니다.");
                    return ;
                }
                // 가입정보 변경
                $("#reqInfoChgYn2").prop("checked", true);
                $("input:radio[name=reqInfoChgYn]").trigger("change");
                
                // 신분증 확인
                $("._selfCert").show();
            }

            MCP.alert("본인인증에 성공 하였습니다.");
            pageObj.telAdvice = false;
            return null;
        } else { // 본인인증 실패 시 처리
            if (authForGr) {
                var resultCd= niceAuthObj.resAuthOjb.RESULT_CODE;
                var errorMsg= niceAuthObj.resAuthOjb.RESULT_MSG;
                if (resultCd == "LOGIN") {
                    MCP.alert(errorMsg, function () {
                        location.href = '/loginForm.do';
                    });
                    return null;
                }
                strMsg= (errorMsg == undefined) ? strMsg : errorMsg;
            }
            MCP.alert(strMsg);
            return null;
        }

    }
}

var viewErrorMgs = function($thatObj, msg ) {
    if ($thatObj.hasClass("c-input") || $thatObj.hasClass("c-select")) {
        $thatObj.parent().removeClass('has-safe').addClass('has-error').after("<p class='c-form__text'>"+msg+"</p>");
    } else if ($thatObj.hasClass("c-input--div2") || $thatObj.hasClass("c-input--div3") ) {
        $thatObj.parent().parent().removeClass('has-safe').addClass('has-error').after("<p class='c-form__text'>"+msg+"</p>");
    }
};


function nextFocus(obj, len, id){
    if($(obj).val().length >= len){
        $('#' + id).focus();
    }
}

//약관 열기
var fnSetEventId = function(eventId){
    pageObj.eventId = eventId;
};

//약관 동의후 닫기
function targetTermsAgree() {
    if (pageObj.eventId === "othersTrnsAllAgree") {
        if (!$("#othersTrnsAgree").is(':checked')) {
            $("#othersTrnsAgree").trigger('click');
        }

        if ($("#othersTrnsAgree").is(':checked') && !$("#othersTrnsKtAgree").is(':checked')) {
            $("#othersTrnsKtAgree").trigger('click');
        }

        return;
    }

    var agree = $('#' + pageObj.eventId);
    if (agree.is(':checked')) {
        return;
    }

    agree.trigger('click');
};


//전화번호 변경에 따른 이벤트
function changeContractNum() {
    //요금제노출변경 START
    var socNm = $("#selContractNum option:selected").attr("data-soc_nm");
    var freeDataCnt = $("#selContractNum option:selected").attr("data-free_data_cnt");
    var freeCallCnt = $("#selContractNum option:selected").attr("data-free_call_cnt");
    var freeSmsCnt = $("#selContractNum option:selected").attr("data-free_sms_cnt");

    var freeData = isNaN(freeDataCnt) ? freeDataCnt : (Math.round(freeDataCnt / 1024 * 10) / 10) +"GB";
    var freeCall = isNaN(freeCallCnt) ? freeCallCnt : freeCallCnt + "분";
    var freeSms = isNaN(freeSmsCnt) ? freeSmsCnt : freeCallCnt + "건";

    $("#rateNm").html("");
    $("#rateNm").html(socNm);

    $("#rateDesc").html("");
    var rateDescHtml = "";
    rateDescHtml += '<span>데이터 ' + freeData + '</span>';
    rateDescHtml += '<span>음성 ' + freeCall + '</span>';
    rateDescHtml += '<span>문자 ' + freeSms + '</span>';
    $("#rateDesc").html(rateDescHtml);
    //노출요금제변경 END

    //onOffType에 따른 신분증 노출 START
    var onOffType = $("#selContractNum option:selected").attr("data-on_off_type");
    if (onOffType == "5") {
        $("._passport").prop("disabled",true);
    } else {
        $("._passport").prop("disabled",false);
    }
    //onOffType에 따른 신분증 노출 END

    // 양도인 고객유형에 따른 노출 START
    var grCstmerType = $("#selContractNum option:selected").attr("data-cstmr_type");

    $(".c-form__text").remove();
    $(".has-error").removeClass("has-error");
    if (grCstmerType == CSTMR_TYPE.NA) {
        $("._grIsTeen").hide();
        $("._grIsForeigner").hide();
        $("._grIsDefault").show();
        $("#grInpNameCertiTitle").html("가입자 정보");
        $("#radCertiTitle").html("본인인증 방법 선택");
        $('#grCstmrType1').prop('disabled', false);
        $('#grCstmrType2').prop('disabled', true);
        $('#grCstmrType3').prop('disabled', true);
        $('#grCstmrType1').prop('checked', true);
    } else if (grCstmerType == CSTMR_TYPE.NM) {
        $("._grIsTeen").show();
        $("._grIsForeigner").hide();
        $("._grIsDefault").show();
        $("#grInpNameCertiTitle").html("가입자 정보(미성년자)");
        $("#radCertiTitle").html("본인인증방법 선택(법정대리인)");
        $('#grCstmrType1').prop('disabled', true);
        $('#grCstmrType2').prop('disabled', false);
        $('#grCstmrType3').prop('disabled', true);
        $('#grCstmrType2').prop('checked', true);
    } else if (grCstmerType == CSTMR_TYPE.FN) {
        $("._grIsTeen").hide();
        $("._grIsForeigner").show();
        $("._grIsDefault").hide();
        $("#grInpNameCertiTitle").html("가입자 정보");
        $("#radCertiTitle").html("본인인증 방법 선택");
        $('#grCstmrType1').prop('disabled', true);
        $('#grCstmrType2').prop('disabled', true);
        $('#grCstmrType3').prop('disabled', false);
        $('#grCstmrType3').prop('checked', true);
    }
    // 양도인 고객유형에 따른 노출 END
}

/* 주소 setting */
