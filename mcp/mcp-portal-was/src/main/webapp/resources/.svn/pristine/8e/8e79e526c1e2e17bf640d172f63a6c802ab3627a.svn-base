    //양도인 신청하기
    $('#btnGrantor').click(function(){
        if ($("#isAuth").val() != "1") {
            MCP.alert("본인 인증이 완료되지 않았습니다. ");
            return false;
        }

        $(".c-form__text").remove();
        $(".has-error").removeClass("has-error");

        validator.config={};
        validator.config['grCstmrName'] = 'isNonEmpty';
        validator.config['cstmrSendTelFn'] = 'isNonEmpty';
        validator.config['cstmrSendTelMn'] = 'isNonEmpty';
        validator.config['cstmrSendTelRn'] = 'isNonEmpty';
        validator.config['cstmrSendTelFn'] = 'isNumFix3';
        validator.config['cstmrSendTelMn'] = 'isNumBetterFixN3';
        validator.config['cstmrSendTelRn'] = 'isNumFix4';
        validator.config['cstmrSendTelFn&cstmrSendTelMn&cstmrSendTelRn'] = 'isPhoneNumberCheck';
        validator.config['notice1'] = 'isNonEmpty';
        validator.config['clauseCntrDelFlag'] = 'isNonEmpty';
        validator.config['notice2'] = 'isNonEmpty';

        var grCstmrType = $("#selContractNum option:selected").attr("data-cstmr_type");
        pageObj.applDataForm.grCstmrName = $.trim($("#grCstmrName").val());
        pageObj.applDataForm.contractNum = $("#selContractNum option:selected").val();
        pageObj.applDataForm.grCstmrType = grCstmrType;
        pageObj.applDataForm.grOnlineAuthType = $('input:radio[name=onlineAuthType]:checked').val();
        pageObj.applDataForm.grReqSeq = pageObj.authObj.reqSeq;
        pageObj.applDataForm.grResSeq = pageObj.authObj.resSeq;
        pageObj.applDataForm.clauseCntrDelFlag = $("#clauseCntrDelFlag").is(":checked") ? "Y":"N";
        pageObj.applDataForm.etcMobile = $.trim($("#cstmrSendTelFn").val()) + $.trim($("#cstmrSendTelMn").val()) + $.trim($("#cstmrSendTelRn").val());

        if (grCstmrType == CSTMR_TYPE.NA) {
            validator.config['grCstmrNativeRrn01'] = 'isNonEmpty';
            validator.config['grCstmrNativeRrn02'] = 'isNonEmpty';
            
            pageObj.applDataForm.grCstmrNativeRrn =$.trim($("#grCstmrNativeRrn01").val()) + $.trim($("#grCstmrNativeRrn02").val()) ;
        } else if (grCstmrType == CSTMR_TYPE.NM) {
            validator.config['grCstmrNativeRrn01'] = 'isNonEmpty';
            validator.config['grCstmrNativeRrn02'] = 'isNonEmpty';
            
            validator.config['grMinorAgentName'] = 'isNonEmpty';
            validator.config['grMinorAgentRelation'] = 'isNonEmpty';
            validator.config['grMinorAgentRrn01'] = 'isNonEmpty';
            validator.config['grMinorAgentRrn02'] = 'isNonEmpty';
            validator.config['grMinorAgentTelFn'] = 'isNonEmpty';
            validator.config['grMinorAgentTelMn'] = 'isNonEmpty';
            validator.config['grMinorAgentTelRn'] = 'isNonEmpty';
            validator.config['grMinorAgentTelFn'] = 'isNumFix3';
            validator.config['grMinorAgentTelMn'] = 'isNumBetterFixN3';
            validator.config['grMinorAgentTelRn'] = 'isNumFix4';
            validator.config['grMinorAgentTelFn&grMinorAgentTelMn&grMinorAgentTelRn'] = 'isPhoneNumberCheck';
            validator.config['grMinorAgentAgrmYn'] = 'isNonEmpty';

            pageObj.applDataForm.grCstmrNativeRrn = $.trim($("#grCstmrNativeRrn01").val()) + $.trim($("#grCstmrNativeRrn02").val()) ;
            pageObj.applDataForm.grMinorAgentName = $.trim($("#grMinorAgentName").val());
            pageObj.applDataForm.grMinorAgentRelation = $("#grMinorAgentRelation").val();
            pageObj.applDataForm.grMinorAgentRrn = $.trim($("#grMinorAgentRrn01").val()) + $.trim($("#grMinorAgentRrn02").val()) ;
            pageObj.applDataForm.grMinorAgentTel = $.trim($("#grMinorAgentTelFn").val()) + $.trim($("#grMinorAgentTelMn").val()) + $.trim($("#grMinorAgentTelRn").val());
            pageObj.applDataForm.grMinorAgentAgrmYn = $("#grMinorAgentAgrmYn").is(":checked") ? "Y":"N";
        } else if (grCstmrType == CSTMR_TYPE.FN) {
            validator.config['grCstmrForeignerRrn01'] = 'isNonEmpty';
            validator.config['grCstmrForeignerRrn02'] = 'isNonEmpty';
            
            pageObj.applDataForm.grCstmrNativeRrn =$.trim($("#grCstmrForeignerRrn01").val()) + $.trim($("#grCstmrForeignerRrn02").val()) ;
        }

        if (validator.validate()) {

            //명의변경 회선과 미납을 위한 연락처가 같은지 체크
            pageObj.applDataForm.etcMobile = $.trim($("#cstmrSendTelFn").val()) + $.trim($("#cstmrSendTelMn").val()) + $.trim($("#cstmrSendTelRn").val());
            pageObj.applDataForm.chkTelType = "NOR";
            var chkData = ajaxCommon.getSerializedData(pageObj.applDataForm);
            ajaxCommon.getItem({
                id:'nameChgChkTelNo'
                ,cache:false
                ,url:'/mypage/nameChgChkTelNo.do'
                ,data: chkData
                ,async:true
                ,dataType:"json"
            },function(jsonObj){
                if (AJAX_RESULT_CODE.SUCCESS !=  jsonObj.RESULT_CODE) {
                    MCP.alert(jsonObj.RESULT_MSG);
                    return false;
                } else {

                    var varData = ajaxCommon.getSerializedData({
                        contractNum:$("#selContractNum option:selected").val()
                    });

                    ajaxCommon.getItem({
                        id:'grantorReqChk'
                        ,cache:false
                        ,url:'/mypage/grantorReqChk.do'
                        ,data: varData
                        ,async:false
                        ,dataType:"json"
                    }, function(jsonObj){
                        if (AJAX_RESULT_CODE.SUCCESS ==  jsonObj.RESULT_CODE) {
                            KTM.Confirm('신청 후 수정이 불가하오니 작성 내용을 다시 확인 부탁드립니다. 양도인 명의변경을 신청하시겠습니까?' ,function () {
                                $('#divGrReq').hide(); //양도인 신청 div 숨기기

                                $('#tdGrReqStat').html("");
                                $('#tdGrReqStat').html("인증 및 신청완료");
                                grantorReqYn = "Y";

                                // 양수인, 양도인 신청완료시 명의변경버튼 생성
                                if (grantorReqYn == "Y" && assigneeReqYn == "Y") {
                                    $('#btnNameChg').removeClass("is-disabled");
                                    $('#btnNameChg').prop("disabled",false);
                                }
                                this.close();
                                MCP.alert("양도인 명의변경 신청이 완료되었습니다.");
                            });
                        } else if (jsonObj.RESULT_CODE == "0002" || jsonObj.RESULT_CODE == "0003" || jsonObj.RESULT_CODE == "0004") { // 정지상태 or 미납상태 or 실사용일90미만
                            MCP.alert("해당 회선은 명의변경이 불가합니다.");
                            return false;
                        } else if (jsonObj.RESULT_CODE == "STEP01"){ // STEP 오류
                            MCP.alert(jsonObj.RESULT_MSG);
                            return false;
                        } else {
                            MCP.alert("양도인 신청에 실패하였습니다.");
                            return false;
                        }
                    })

                }
            })

        } else {
            var errId = validator.getErrorId();
            MCP.alert(validator.getErrorMsg(),function (){
                $selectObj = $("#"+errId);
                viewErrorMgs($selectObj, validator.getErrorMsg());
            });
            $(this).prop("checked", "");
        }
    })

    //양수인 신청하기
    $('#btnAssignee').click(function(){
        if ($("#isAuth2").val() != "1") {
            MCP.alert("본인 인증이 완료되지 않았습니다. ");
