    <function>
        <name>getCurrentMenuInfo</name>
        <function-class>com.ktmmobile.mcp.common.util.SessionUtils</function-class>
        <function-signature>com.ktmmobile.mcp.common.dto.WorkNotiDto getCurrentMenuUrl())</function-signature>
    </function>

    <function>
        <name>getCurrentMenuName</name>
