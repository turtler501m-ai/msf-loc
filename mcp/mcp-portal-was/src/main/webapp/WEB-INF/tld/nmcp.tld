<taglib version="2.0" xmlns="http://java.sun.com/xml/ns/j2ee"
                      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                      xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee web-jsptaglibrary_2_0.xsd">
    <tlib-version>1.0</tlib-version>
    <short-name>nmcp</short-name>
    <uri>nmcp.tag</uri>


    <tag>
        <description>
             페이징 Tag 사용
        </description>
        <name>pageInfo</name>
        <tag-class>com.ktmmobile.mcp.common.tag.PageInfoTag</tag-class>
        <body-content>empty</body-content>
        <attribute>
            <description>
                pageInfoBean : pageInfoBean내용전달
            </description>
            <name>pageInfoBean</name>
            <required>true</required>
            <rtexprvalue>true</rtexprvalue>
        </attribute>
        <attribute>
            <description>
                function : javascript 호출 변수
            </description>
            <name>function</name>
            <required>true</required>
            <rtexprvalue>true</rtexprvalue>
        </attribute>
    </tag>

    <function>
        <name>getServerInfo</name>
        <function-class>com.ktmmobile.mcp.common.util.SessionUtils</function-class>
        <function-signature>java.lang.String getServerInfo()</function-signature>
    </function>

    <function>
        <name>getCookieRoleMenuList</name>
        <function-class>com.ktmmobile.mcp.common.util.SessionUtils</function-class>
        <function-signature>java.util.List getRoleMenuList(java.lang.String,java.lang.String)</function-signature>
    </function>

    <function>
        <name>hasMenuAuthWire</name>
        <function-class>com.ktmmobile.mcp.common.util.SessionUtils</function-class>
        <function-signature>boolean hasMenuAuthWire()</function-signature>
    </function>

    <!-- 현재 날짜 -->
    <function>
        <name>getDateToCurrent</name>
        <function-class>com.ktmmobile.mcp.common.util.DateTimeUtil</function-class>
        <function-signature>java.util.Date getDateToCurrent(int)</function-signature>
    </function>


    <!-- 현재 날짜 -->
    <function>
        <name>chcekToAfterDate</name>
        <function-class>com.ktmmobile.mcp.common.util.DateTimeUtil</function-class>
        <function-signature>boolean chcekToAfterDate(java.util.Date)</function-signature>
    </function>


    <!-- 특정 개월(month)을  더한 시각 -->
    <function>
        <name>addMonths</name>
        <function-class>com.ktmmobile.mcp.common.util.DateTimeUtil</function-class>
        <function-signature>java.lang.String addMonths(java.lang.String,int,java.lang.String)</function-signature>
    </function>

    <!-- 현재월 마지막 일자 -->
    <function>
        <name>getLastDayOfThisMonth</name>
        <function-class>com.ktmmobile.mcp.common.util.DateTimeUtil</function-class>
        <function-signature>java.util.Date getLastDayOfThisMonth()</function-signature>
    </function>

    <!-- 공통 코드 조회 -->
    <function>
        <name>getCodeList</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>java.util.List getCodeList(java.lang.String)</function-signature>
    </function>

    <!-- 공통 코드명 조회 -->
    <function>
        <name>getCodeNm</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>com.java.lang.String getCodeNm(java.lang.String,java.lang.String)</function-signature>
    </function>


    <!-- 공통 코드명 조회 -->
    <function>
        <name>getCodeNmDto</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>com.ktmmobile.mcp.common.dto.db.NmcpCdDtlDto getCodeNmDto(java.lang.String,java.lang.String)</function-signature>
    </function>

    <!-- 공통 코드명 조회 -->
    <function>
        <name>getFtranPrice</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>com.java.lang.String getFtranPrice()</function-signature>
    </function>

    <!-- 상세코드설명 조회 -->
    <function>
        <name>getCodeDesc</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>com.java.lang.String getCodeDesc(java.lang.String,java.lang.String)</function-signature>
    </function>

    <!-- 상세 코드명으로 공통코드 상세 조회  -->
    <function>
        <name>getCodeByDtlCdNm</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>com.ktmmobile.mcp.common.dto.db.NmcpCdDtlDto getCodeByDtlCdNm(java.lang.String,java.lang.String)</function-signature>
    </function>

    <function>
        <name>isContainsTrick</name>
        <function-class>com.ktmmobile.mcp.common.util.NmcpServiceUtils</function-class>
        <function-signature>boolean isContainsTrick(java.lang.String)</function-signature>
    </function>

    <!-- 이름 마스킹 -->
    <function>
        <name>getMaskedName</name>
        <function-class>com.ktmmobile.mcp.common.util.MaskingUtil</function-class>
        <function-signature>java.lang.String getMaskedName(java.lang.String)
        </function-signature>
    </function>

    <!-- 주소 마스킹 -->
    <function>
        <name>getMaskedByAddressNew2</name>
        <function-class>com.ktmmobile.mcp.common.util.MaskingUtil</function-class>
        <function-signature>java.lang.String getMaskedByAddressNew2(java.lang.String)
        </function-signature>
    </function>

     <!-- 이메일 마스킹 -->
    <function>
        <name>getMaskedEmail2</name>
        <function-class>com.ktmmobile.mcp.common.util.MaskingUtil</function-class>
        <function-signature>java.lang.String getMaskedEmail2(java.lang.String)
        </function-signature>
    </function>

     <!-- 전화번호 마스킹 -->
    <function>
        <name>getMaskedTelNo</name>
        <function-class>com.ktmmobile.mcp.common.util.MaskingUtil</function-class>
        <function-signature>java.lang.String getMaskedTelNo(java.lang.String)
        </function-signature>
    </function>

     <!-- 아이디 마스킹 -->
    <function>
        <name>getMaskedId</name>
        <function-class>com.ktmmobile.mcp.common.util.MaskingUtil</function-class>
        <function-signature>java.lang.String getMaskedId(java.lang.String)
        </function-signature>
    </function>

    <!-- html Entity숫자 ==>문자 -->
    <function>
        <name>unescapeXml</name>
        <function-class>org.apache.commons.lang3.StringEscapeUtils</function-class>
        <function-signature>java.lang.String unescapeXml(java.lang.String)</function-signature>
    </function>

    <function>
        <name>getMobileFullNum</name>
        <function-class>com.ktmmobile.mcp.common.util.StringUtil</function-class>
        <function-signature>java.lang.String getMobileFullNum(java.lang.String)</function-signature>
    </function>
    <!--  원단위 절삭 -->
    <function>
        <name>cutNearestWon</name>
        <function-class>com.ktmmobile.mcp.common.util.StringUtil</function-class>
        <function-signature>java.lang.String cutNearestWon(java.lang.String)</function-signature>
    </function>

    <!--  원단위 절삭 -->
    <function>
        <name>getRandomInt</name>
        <function-class>com.ktmmobile.mcp.common.util.StringUtil</function-class>
        <function-signature>int getRandomInt(int)</function-signature>
    </function>

    <!--  html 변환 -->
    <function>
        <name>convertHtmlchars</name>
        <function-class>com.ktmmobile.mcp.common.util.ParseHtmlTagUtil</function-class>
        <function-signature>java.lang.String convertHtmlchars(java.lang.String)</function-signature>
    </function>

    <!-- hasLoginUserSessionBean 세션  -->
    <function>
        <name>hasLoginUserSessionBean</name>
        <function-class>com.ktmmobile.mcp.common.util.SessionUtils</function-class>
