<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="FormDtlMapper">

    <select id="FormDtlView" resultType="com.ktmmobile.mcp.texting.dto.FormDtlDTO" parameterType="com.ktmmobile.mcp.texting.dto.FormDtlDTO">
                    SELECT
                         DTL_CD
                       , DTL_CD_NM
                       ,PSTNG_START_DATE
                       ,PSTNG_END_DATE
                    FROM NMCP_CD_DTL
                    WHERE CD_GROUP_ID = #{cdGroupId1}
                    AND DTL_CD = #{cdGroupId2}
                    AND USE_YN = 'Y'
                    ORDER BY INDC_ODRG
    </select>

  <select id="getFormList" resultType="com.ktmmobile.mcp.texting.dto.FormDtlDTO" parameterType="com.ktmmobile.mcp.texting.dto.FormDtlDTO">
                    SELECT
                         DTL_CD
                       , DTL_CD_NM
                       ,PSTNG_START_DATE
                       ,PSTNG_END_DATE
                    FROM NMCP_CD_DTL
                    WHERE CD_GROUP_ID = #{cdGroupId1}
                    AND USE_YN = 'Y'
                    ORDER BY INDC_ODRG
   </select>

   </mapper>
